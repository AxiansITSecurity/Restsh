#!/usr/bin/env bash

# Author: Juergen Mang <juergen.mang@axians.de>
# Date: 2025-04-11

# Shortdesc: Test suite for mo.f5.as3 library.
# Desc:
# Test suite for mo.f5.as3 library.

# Strict error handling
set -eEuo pipefail

test.mo.f5.as3.MO_F5_AS3_INCLUDE_DECLARATION() {
    local TMP
    TMP=$(mktemp -d)
    local VAR_TEST1="test string"
    local ARRAY_TEST2=("/ratelimit/test1,5 30 60" "/ratelimit/test2,10 60 120")
    local ARRAY_TEST3=()
    cat > "$TMP/parent.json" << EOL
{
    {{MO_F5_AS3_INCLUDE_DECLARATION '$TMP/include.json' '.Common' 'TEST1=VAR_TEST1' 'TEST2=ARRAY_TEST2' 'TEST3=ARRAY_TEST3'}}
}
EOL
    cat > "$TMP/include.json" << EOL
{
    "Common": {
        "records": [
            {{#ARG_TEST2}}
                {{MO_COMMA_IF_NOT_FIRST}}
                {
                    "{{MO_CSV_GET_FIRST {{.}}}}": "{{MO_CSV_GET_LAST {{.}}}}"
                }
            {{/ARG_TEST2}}
        ],
        "empty": [
            {{#ARG_TEST3}}
                {{MO_COMMA_IF_NOT_FIRST}}
                {
                    "{{MO_CSV_GET_FIRST {{.}}}}": "{{MO_CSV_GET_LAST {{.}}}}"
                }
            {{/ARG_TEST3}}
        ],
        "string": "{{ARG_TEST1}}"
    }
}
EOL
    JSON=$($RESTSH_MO -- "$TMP/parent.json")
    echo "$JSON"
    rm -rf "$TMP"
    local RECORD0 RECORD1 STR
    RECORD0=$(JQ -r '.records[0]."/ratelimit/test1"' <<< "$JSON")
    RECORD1=$(JQ -r '.records[1]."/ratelimit/test2"' <<< "$JSON")
    STR=$(JQ -r '.string' <<< "$JSON")
    [ "$RECORD0" = "5 30 60" ]
    [ "$RECORD1" = "10 60 120" ]
    [ "$STR" = "test string" ]
}

# shellcheck disable=SC2034
TESTS_MO_F5_AS3=(
    test.mo.f5.as3.MO_F5_AS3_INCLUDE_DECLARATION
)
