#!/usr/bin/env bash

# Author: Juergen Mang <juergen.mang@axians.de>
# Date: 2025-04-11

# Shortdesc: Test suite for mo.f5.as3 library.
# Desc:
# Test suite for mo.f5.as3 library.

# shellcheck disable=SC2034 # Variables are used in the MO templates

# Strict error handling
set -eEuo pipefail

test.mo.f5.as3.MO_IP_RANGE.single() {
    # Test with start = end
    local TMP
    TMP=$(mktemp -d)
        cat > "$TMP/parent.json" << EOL
{
    "Common": {
        "records": [
            {{MO_IP_RANGE '10.1.1.10' '10.1.1.10'}}
        ]
    }
}
EOL
    JSON=$($RESTSH_MO -- "$TMP/parent.json")
    echo "$JSON"
    RECORD_FIRST=$(JQ -r '.Common.records[0]' <<< "$JSON")
    RECORD_LAST=$(JQ -r '.Common.records[1]' <<< "$JSON")
    [ "$RECORD_FIRST" = "10.1.1.10" ] || return 1
    [ "$RECORD_LAST" = "null" ] || return 1
    rm -rf "$TMP"
}

test.mo.f5.as3.MO_IP_RANGE.range() {
    local TMP
    TMP=$(mktemp -d)
    cat > "$TMP/parent.json" << EOL
{
    "Common": {
        "records": [
            {{MO_IP_RANGE '10.1.1.10' '10.1.1.20'}}
        ]
    }
}
EOL
    JSON=$($RESTSH_MO -- "$TMP/parent.json")
    echo "$JSON"
    local RECORD_FIRST RECORD_LAST
    RECORD_FIRST=$(JQ -r '.Common.records[0]' <<< "$JSON")
    RECORD_LAST=$(JQ -r '.Common.records[10]' <<< "$JSON")
    [ "$RECORD_FIRST" = "10.1.1.10" ] || return 1
    [ "$RECORD_LAST" = "10.1.1.20" ] || return 1
    rm -rf "$TMP"
}

test.mo.f5.as3.MO_F5_AS3_INCLUDE_IRULES_FROM_FOLDER() {
    local TMP
    TMP=$(mktemp -d)
    mkdir "$TMP/irules"
    cat > "$TMP/parent.json" << EOL
{
    "Common": {
        {{MO_F5_AS3_INCLUDE_IRULES_FROM_FOLDER '$TMP/irules'}}
    }
}
EOL
    echo "test0" > "$TMP/irules/test0.irule"
    echo "test1" > "$TMP/irules/test1.irule"
    JSON=$($RESTSH_MO -- "$TMP/parent.json")
    echo "$JSON"
    rm -rf "$TMP"
    local IRULE0
    local IRULE1
    IRULE0=$(JQ -r '.Common.test0.iRule.base64' <<< "$JSON")
    IRULE1=$(JQ -r '.Common.test1.iRule.base64' <<< "$JSON")
    [ "$(base64 -d <<< "$IRULE0")" = "test0" ] || return 1
    [ "$(base64 -d <<< "$IRULE1")" = "test1" ] || return 1
}

test.mo.f5.as3.MO_F5_AS3_INCLUDE_IFILES_FROM_FOLDER() {
    local TMP
    TMP=$(mktemp -d)
    mkdir "$TMP/ifiles"
    cat > "$TMP/parent.json" << EOL
{
    "Common": {
        {{MO_F5_AS3_INCLUDE_IFILES_FROM_FOLDER '$TMP/ifiles'}}
    }
}
EOL
    echo "test0" > "$TMP/ifiles/test0.txt"
    echo "test1" > "$TMP/ifiles/test1.txt"
    JSON=$($RESTSH_MO -- "$TMP/parent.json")
    echo "$JSON"
    rm -rf "$TMP"
    local IFILE0
    local IFILE1
    IFILE0=$(JQ -r '.Common."test0.txt".iFile.base64' <<< "$JSON")
    IFILE1=$(JQ -r '.Common."test1.txt".iFile.base64' <<< "$JSON")
    [ "$(base64 -d <<< "$IFILE0")" = "test0" ] || return 1
    [ "$(base64 -d <<< "$IFILE1")" = "test1" ] || return 1
}

test.mo.f5.as3.MO_F5_AS3_INCLUDE_DECLARATION() {
    local TMP
    TMP=$(mktemp -d)
    local VAR_TEST1="test string"
    local ARRAY_TEST2=("/ratelimit/test1,5 30 60" "/ratelimit/test2,10 60 120" "/ratelimit/test3,\$foo")
    local ARRAY_TEST3=()
    cat > "$TMP/parent.json" << EOL
{
    {{MO_F5_AS3_INCLUDE_DECLARATION '$TMP/include.json' '.Common' 'TEST1=VAR_TEST1' 'TEST2=ARRAY_TEST2' 'TEST3=ARRAY_TEST3' 'TEST4=abc'}}
}
EOL
    cat > "$TMP/include.json" << EOL
{
    "Common": {
        "records": [
            {{#ARG_TEST2}}
                {{MO_COMMA_IF_NOT_FIRST}}
                {
                    "{{MO_CSV_GET_FIRST {{.}}}}": "{{MO_CSV_GET_LAST {{.}}}}"
                }
            {{/ARG_TEST2}}
        ],
        "empty": [
            {{#ARG_TEST3}}
                {{MO_COMMA_IF_NOT_FIRST}}
                {
                    "{{MO_CSV_GET_FIRST {{.}}}}": "{{MO_CSV_GET_LAST {{.}}}}"
                }
            {{/ARG_TEST3}}
        ],
        "string": "{{ARG_TEST1}}",
        "fixed": "{{ARG_TEST4}}"
    }
}
EOL
    JSON=$($RESTSH_MO -- "$TMP/parent.json")
    echo "$JSON"
    rm -rf "$TMP"
    local RECORD0 RECORD1 STR FIXED
    RECORD0=$(JQ -r '.records[0]."/ratelimit/test1"' <<< "$JSON")
    RECORD1=$(JQ -r '.records[1]."/ratelimit/test2"' <<< "$JSON")
    RECORD2=$(JQ -r '.records[2]."/ratelimit/test3"' <<< "$JSON")
    STR=$(JQ -r '.string' <<< "$JSON")
    FIXED=$(JQ -r '.fixed' <<< "$JSON")
    [ "$RECORD0" = "5 30 60" ] || return 1
    [ "$RECORD1" = "10 60 120" ] || return 1
    [ "$RECORD2" = "\$foo" ] || return 1
    [ "$STR" = "test string" ] || return 1
    [ "$FIXEDR" = "abc" ] || return 1
}

TESTS_MO_F5_AS3=(
    test.mo.f5.as3.MO_F5_AS3_INCLUDE_DECLARATION
    test.mo.f5.as3.MO_IP_RANGE.single
    test.mo.f5.as3.MO_IP_RANGE.range
    test.mo.f5.as3.MO_F5_AS3_INCLUDE_IRULES_FROM_FOLDER
    test.mo.f5.as3.MO_F5_AS3_INCLUDE_IFILES_FROM_FOLDER
)
