test.mo.functions.MO_INCLUDE_PLAIN.json() {
    local TMP
    TMP=$(mktemp -d)
    printf "abc" > "$TMP/test"
    cat > "$TMP/parent.json" << EOL
{
    "Common": {
        "key1": "{{MO_INCLUDE_PLAIN 'test' '$TMP'}}",
        "key2": "{{MO_INCLUDE_PLAIN '$TMP/test'}}"
    }
}
EOL
    JSON=$($RESTSH_MO -- "$TMP/parent.json")
    echo "$JSON"
    rm -rf "$TMP"
    local RECORD_FIRST RECORD_LAST
    RECORD_FIRST=$(JQ -r '.Common.key1' <<< "$JSON")
    RECORD_LAST=$(JQ -r '.Common.key2' <<< "$JSON")
    [ "$RECORD_FIRST" = "abc" ] || return 1
    [ "$RECORD_LAST" = "abc" ] || return 1
}

test.mo.functions.MO_INCLUDE_JSON_ENCODE() {
    local TMP
    TMP=$(mktemp -d)
    echo 'a"bc' > "$TMP/test"
    cat > "$TMP/parent.json" << EOL
{
    "Common": {
        "key1": {{MO_INCLUDE_JSON_ENCODE 'test' '$TMP'}},
        "key2": {{MO_INCLUDE_JSON_ENCODE '$TMP/test'}}
    }
}
EOL
    local VALUE
    VALUE=$(JQ -n --arg v "$(<"$TMP/test")" '{$v}' | JQ -r '.v')
    JSON=$($RESTSH_MO -- "$TMP/parent.json")
    echo "$JSON"
    rm -rf "$TMP"
    local RECORD_FIRST RECORD_LAST
    RECORD_FIRST=$(JQ -r '.Common.key1' <<< "$JSON")
    RECORD_LAST=$(JQ -r '.Common.key2' <<< "$JSON")
    printf "%s\n" "$RECORD_FIRST"
    [ "$RECORD_FIRST" = "$VALUE" ] || return 1
    [ "$RECORD_LAST" = "$VALUE" ] || return 1
}

test.mo.functions.MO_INCLUDE_PARSE.arg1() {
    local TMP
    TMP=$(mktemp -d)
    local KEY1="VALUE1"
    echo "{{KEY1}}" > "$TMP/test"
    local MO_FUNCTION_ARGS=("$TMP/test")
    local OUT
    OUT=$(MO_INCLUDE_PARSE)
    [ "$OUT" = "VALUE1" ] || return 1
    unset MO_FUNCTION_ARGS
    unset OUT
}

test.mo.functions.MO_INCLUDE_PARSE.arg2() {
    local TMP
    TMP=$(mktemp -d)
    local KEY1="VALUE1"
    echo "{{KEY1}}" > "$TMP/test"
    local MO_FUNCTION_ARGS=("test" "$TMP")
    local OUT
    OUT=$(MO_INCLUDE_PARSE)
    [ "$OUT" = "VALUE1" ] || return 1
    unset MO_FUNCTION_ARGS
    unset OUT
}

test.mo.functions.MO_INCLUDE_PARSE.json() {
    local TMP
    TMP=$(mktemp -d)
    local VAR_TEST=("test1" "test2")
    cat > "$TMP/parent.json" << EOL
{
    "Tenant": {{MO_INCLUDE_PARSE '$TMP/include.json'}}
}
EOL
    cat > "$TMP/include.json" << EOL
{
    "Common": {
        "records": [
            {{#VAR_TEST}}
                {{MO_COMMA_IF_NOT_FIRST}}
                "{{.}}"
            {{/VAR_TEST}}
        ]
    }
}
EOL
    JSON=$($RESTSH_MO -- "$TMP/parent.json")
    echo "$JSON"
    rm -rf "$TMP"
    local RECORD0 RECORD1 STR
    RECORD0=$(JQ -r '.Tenant.Common.records[0]' <<< "$JSON")
    RECORD1=$(JQ -r '.Tenant.Common.records[1]' <<< "$JSON")
    STR=$(JQ -r '.string' <<< "$JSON")
    [ "$RECORD0" = "test1" ] || return 1
    [ "$RECORD1" = "test2" ] || return 1
}

test.mo.functions.MO_VAR_PARSE() {
    local KEY1="VALUE1"
    local STRING="{{KEY1}}"
    local MO_FUNCTION_ARGS=("STRING")
    local OUT
    OUT=$(MO_VAR_PARSE)
    [ "$OUT" = "VALUE1" ] || return 1
    unset MO_FUNCTION_ARGS
    unset OUT
}

test.mo.functions.MO_VAR_PARSE.json() {
    local TMP
    TMP=$(mktemp -d)
    local VAR_TEST=("test1" "test2")
    cat > "$TMP/parent.json" << EOL
{
    "Tenant": {{MO_VAR_PARSE 'INCLUDE'}}
}
EOL
    local INCLUDE='{
    "Common": {
        "records": [
            {{#VAR_TEST}}
                {{MO_COMMA_IF_NOT_FIRST}}
                "{{.}}"
            {{/VAR_TEST}}
        ]
    }
}'
    JSON=$($RESTSH_MO -- "$TMP/parent.json")
    echo "$JSON"
    rm -rf "$TMP"
    local RECORD0 RECORD1 STR
    RECORD0=$(JQ -r '.Tenant.Common.records[0]' <<< "$JSON")
    RECORD1=$(JQ -r '.Tenant.Common.records[1]' <<< "$JSON")
    STR=$(JQ -r '.string' <<< "$JSON")
    [ "$RECORD0" = "test1" ] || return 1
    [ "$RECORD1" = "test2" ] || return 1
}

test.mo.functions.MO_VAR_PARSE_IF() {
    local KEY1="VALUE1"
    local STRING="{{KEY1}}"
    local F5_VERSION="17"
    local MO_FUNCTION_ARGS=("F5_VERSION" "17" "STRING")
    local OUT
    OUT=$(MO_VAR_PARSE_IF)
    [ "$OUT" = "VALUE1" ] || return 1
    unset MO_FUNCTION_ARGS
    unset OUT
}

test.mo.functions.MO_VAR_PARSE_IF.json() {
    local TMP
    TMP=$(mktemp -d)
    local VAR_TEST=("test1" "test2")
    local F5_VERSION="17"
    cat > "$TMP/parent.json" << EOL
{{MO_VAR_PARSE_IF 'F5_VERSION' '17' 'INCLUDE'}}
{{MO_VAR_PARSE_IF 'F5_VERSION' '16' 'INCLUDE2'}}
EOL
    local INCLUDE='{
    "Common": {
        "records": [
            {{#VAR_TEST}}
                {{MO_COMMA_IF_NOT_FIRST}}
                "{{.}}"
            {{/VAR_TEST}}
        ]
    }
}'
    local INCLUDE2='{
    "Common2": {
        "records": [
            {{#VAR_TEST}}
                {{MO_COMMA_IF_NOT_FIRST}}
                "{{.}}"
            {{/VAR_TEST}}
        ]
    }
}'
    JSON=$($RESTSH_MO -- "$TMP/parent.json")
    echo "$JSON"
    rm -rf "$TMP"
    local RECORD0 RECORD1 STR
    RECORD0=$(JQ -r '.Common.records[0]' <<< "$JSON")
    RECORD1=$(JQ -r '.Common.records[1]' <<< "$JSON")
    STR=$(JQ -r '.string' <<< "$JSON")
    [ "$RECORD0" = "test1" ] || return 1
    [ "$RECORD1" = "test2" ] || return 1
    if JQE -r '.Common2.records[0]' <<< "$JSON"
    then
        return 1
    fi
}

