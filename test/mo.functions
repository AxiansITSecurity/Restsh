test.mo.functions.MO_INCLUDE_PLAIN() {
    local TMP
    TMP=$(mktemp -d)
    printf "abc" > "$TMP/test"
    cat > "$TMP/parent.json" << EOL
{
    "Common": {
        "key1": "{{MO_INCLUDE_PLAIN 'test' '$TMP'}}",
        "key2": "{{MO_INCLUDE_PLAIN '$TMP/test'}}"
    }
}
EOL
    JSON=$($RESTSH_MO -- "$TMP/parent.json")
    echo "$JSON"
    rm -rf "$TMP"
    local RECORD_FIRST RECORD_LAST
    RECORD_FIRST=$(JQ -r '.Common.key1' <<< "$JSON")
    RECORD_LAST=$(JQ -r '.Common.key2' <<< "$JSON")
    [ "$RECORD_FIRST" = "abc" ]
    [ "$RECORD_LAST" = "abc" ]
}

test.mo.functions.MO_INCLUDE_JSON_ENCODE() {
    local TMP
    TMP=$(mktemp -d)
    echo 'a"bc' > "$TMP/test"
    cat > "$TMP/parent.json" << EOL
{
    "Common": {
        "key1": {{MO_INCLUDE_JSON_ENCODE 'test' '$TMP'}},
        "key2": {{MO_INCLUDE_JSON_ENCODE '$TMP/test'}}
    }
}
EOL
    local VALUE
    VALUE=$(JQ -n --arg v "$(<"$TMP/test")" '{$v}' | JQ -r '.v')
    JSON=$($RESTSH_MO -- "$TMP/parent.json")
    echo "$JSON"
    rm -rf "$TMP"
    local RECORD_FIRST RECORD_LAST
    RECORD_FIRST=$(JQ -r '.Common.key1' <<< "$JSON")
    RECORD_LAST=$(JQ -r '.Common.key2' <<< "$JSON")
    printf "%s\n" "$RECORD_FIRST"
    [ "$RECORD_FIRST" = "$VALUE" ]
    [ "$RECORD_LAST" = "$VALUE" ]
}

test.mo.functions.MO_INCLUDE_PARSE() {
    local TMP
    TMP=$(mktemp -d)
    local VAR_TEST=("test1" "test2")
    cat > "$TMP/parent.json" << EOL
{
    "Tenant": {{MO_INCLUDE_PARSE '$TMP/include.json'}}
}
EOL
    cat > "$TMP/include.json" << EOL
{
    "Common": {
        "records": [
            {{#VAR_TEST}}
                {{MO_COMMA_IF_NOT_FIRST}}
                "{{.}}"
            {{/VAR_TEST}}
        ]
    }
}
EOL
    JSON=$($RESTSH_MO -- "$TMP/parent.json")
    echo "$JSON"
    rm -rf "$TMP"
    local RECORD0 RECORD1 STR
    RECORD0=$(JQ -r '.Tenant.Common.records[0]' <<< "$JSON")
    RECORD1=$(JQ -r '.Tenant.Common.records[1]' <<< "$JSON")
    STR=$(JQ -r '.string' <<< "$JSON")
    [ "$RECORD0" = "test1" ]
    [ "$RECORD1" = "test2" ]
}

test.mo.functions.MO_VAR_PARSE() {
    local TMP
    TMP=$(mktemp -d)
    local VAR_TEST=("test1" "test2")
    cat > "$TMP/parent.json" << EOL
{
    "Tenant": {{MO_VAR_PARSE 'INCLUDE'}}
}
EOL
    local INCLUDE='{
    "Common": {
        "records": [
            {{#VAR_TEST}}
                {{MO_COMMA_IF_NOT_FIRST}}
                "{{.}}"
            {{/VAR_TEST}}
        ]
    }
}'
    JSON=$($RESTSH_MO -- "$TMP/parent.json")
    echo "$JSON"
    rm -rf "$TMP"
    local RECORD0 RECORD1 STR
    RECORD0=$(JQ -r '.Tenant.Common.records[0]' <<< "$JSON")
    RECORD1=$(JQ -r '.Tenant.Common.records[1]' <<< "$JSON")
    STR=$(JQ -r '.string' <<< "$JSON")
    [ "$RECORD0" = "test1" ]
    [ "$RECORD1" = "test2" ]
}

test.mo.functions.MO_VAR_PARSE_IF() {
    local TMP
    TMP=$(mktemp -d)
    local VAR_TEST=("test1" "test2")
    local F5_VERSION="17"
    cat > "$TMP/parent.json" << EOL
{{MO_VAR_PARSE_IF 'F5_VERSION' '17' 'INCLUDE'}}
{{MO_VAR_PARSE_IF 'F5_VERSION' '16' 'INCLUDE2'}}
EOL
    local INCLUDE='{
    "Common": {
        "records": [
            {{#VAR_TEST}}
                {{MO_COMMA_IF_NOT_FIRST}}
                "{{.}}"
            {{/VAR_TEST}}
        ]
    }
}'
    local INCLUDE2='{
    "Common2": {
        "records": [
            {{#VAR_TEST}}
                {{MO_COMMA_IF_NOT_FIRST}}
                "{{.}}"
            {{/VAR_TEST}}
        ]
    }
}'
    JSON=$($RESTSH_MO -- "$TMP/parent.json")
    echo "$JSON"
    rm -rf "$TMP"
    local RECORD0 RECORD1 STR
    RECORD0=$(JQ -r '.Common.records[0]' <<< "$JSON")
    RECORD1=$(JQ -r '.Common.records[1]' <<< "$JSON")
    STR=$(JQ -r '.string' <<< "$JSON")
    [ "$RECORD0" = "test1" ]
    [ "$RECORD1" = "test2" ]
    if JQE -r '.Common2.records[0]' <<< "$JSON"
    then
        return 1
    fi
}

TESTS_MO_FUNCTIONS=(
    test.mo.functions.MO_COMMA_IF_NOT_FIRST
    test.mo.functions.MO_COMMA_IF_NOT_EMPTY
    test.mo.functions.MO_VALUE_OR_DEFAULT
    test.mo.functions.MO_VALUE_EXPAND_OR_DEFAULT
    test.mo.functions.MO_TRUE_IF_NOT_EMPTY
    test.mo.functions.MO_CSV_GET
    test.mo.functions.MO_BASE64URL
    test.mo.functions.MO_INCLUDE_BASE64
    test.mo.functions.MO_INCLUDE_BASE64URL
    test.mo.functions.MO_INCLUDE_PLAIN
    test.mo.functions.MO_INCLUDE_JSON_ENCODE
    test.mo.functions.MO_INCLUDE_PARSE
    test.mo.functions.MO_VAR_PARSE
    test.mo.functions.MO_VAR_PARSE_IF
)
