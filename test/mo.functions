test.mo.functions.MO_CSV_GET() {
    local TMP
    TMP=$(mktemp -d)
    local CSV="test0,test1,test2"
    cat > "$TMP/parent.json" << EOL
{
    "Common": {
        {{#CSV}}
            "key0": "{{MO_CSV_GET_FIRST {{.}}}}",
            "key1": "{{MO_CSV_GET_ENTRY {{.}} '1'}}",
            "key2": "{{MO_CSV_GET_LAST {{.}}}}",
            "key3": "{{MO_CSV_GET_ENTRY_OR_DEFAULT {{.}} '3' 'default'}}"
        {{/CSV}}
    }
}
EOL
    JSON=$($RESTSH_MO -- "$TMP/parent.json")
    echo "$JSON"
    rm -rf "$TMP"
    local RECORD_FIRST RECORD_ENTRY RECORD_LAST RECORD_DEFAULT
    RECORD_FIRST=$(JQ -r '.Common.key0' <<< "$JSON")
    RECORD_ENTRY=$(JQ -r '.Common.key1' <<< "$JSON")
    RECORD_LAST=$(JQ -r '.Common.key2' <<< "$JSON")
    RECORD_DEFAULT=$(JQ -r '.Common.key3' <<< "$JSON")
    [ "$RECORD_FIRST" = "test0" ] || return 1
    [ "$RECORD_ENTRY" = "test1" ] || return 1
    [ "$RECORD_LAST" = "test2" ] || return 1
    [ "$RECORD_DEFAULT" = "default" ] || return 1
}

test.mo.functions.MO_CSV_GET_ENTRY() {
    local MO_FUNCTION_ARGS=("test0,test1,test2" "1")
    local OUT
    OUT=$(MO_CSV_GET_ENTRY)
    [ "$OUT" = "test1" ] || return 1
    unset MO_FUNCTION_ARGS
    unset OUT
}

test.mo.functions.MO_CSV_GET_ENTRY_OR_DEFAULT.default() {
    local MO_FUNCTION_ARGS=("test0,test1,test2" "3" "default_value")
    local OUT
    OUT=$(MO_CSV_GET_ENTRY_OR_DEFAULT)
    [ "$OUT" = "default_value" ] || return 1
    unset MO_FUNCTION_ARGS
    unset OUT
}

test.mo.functions.MO_CSV_GET_ENTRY_OR_DEFAULT.value() {
    local MO_FUNCTION_ARGS=("test0,test1,test2" "2" "default_value")
    local OUT
    OUT=$(MO_CSV_GET_ENTRY_OR_DEFAULT)
    [ "$OUT" = "test2" ] || return 1
    unset MO_FUNCTION_ARGS
    unset OUT
}

test.mo.functions.MO_INCLUDE_BASE64.arg1() {
    local TMP
    TMP=$(mktemp -d)
    echo "abc" > "$TMP/test"

    local MO_FUNCTION_ARGS=("$TMP/test")
    local OUT
    OUT=$(MO_INCLUDE_BASE64)
    rm -rf "$TMP"
    [ "$OUT" = "YWJjCg==" ] || return 1
    unset MO_FUNCTION_ARGS
    unset OUT
}

test.mo.functions.MO_INCLUDE_BASE64.arg2() {
    local TMP
    TMP=$(mktemp -d)
    echo "abc" > "$TMP/test"

    local MO_FUNCTION_ARGS=("test" "$TMP")
    local OUT
    OUT=$(MO_INCLUDE_BASE64)
    rm -rf "$TMP"
    [ "$OUT" = "YWJjCg==" ] || return 1
    unset MO_FUNCTION_ARGS
    unset OUT
}

test.mo.functions.MO_INCLUDE_BASE64.json() {
