#!/usr/bin/env bash

# Author: Juergen Mang <juergen.mang@axians.de>
# Date: 2025-04-17

# Shortdesc: Test suite for mo.functions library.
# Desc:
# Test suite for mo.functions library.

# shellcheck disable=SC2034 # Array is used in test.sh

# Strict error handling
set -eEuo pipefail

test.mo.functions.MO_COMMA_IF_NOT_FIRST() {
    local TMP
    TMP=$(mktemp -d)
    local ARRAY=("test0" "test1" "test2")
    cat > "$TMP/parent.json" << EOL
{
    "Common": {
        "records": [
            {{#ARRAY}}
                {{MO_COMMA_IF_NOT_FIRST}}
                "{{.}}"
            {{/ARRAY}}
        ]
    }
}
EOL
    JSON=$($RESTSH_MO -- "$TMP/parent.json")
    echo "$JSON"
    rm -rf "$TMP"
    local RECORD_FIRST RECORD_LAST
    RECORD_FIRST=$(JQ -r '.Common.records[0]' <<< "$JSON")
    RECORD_LAST=$(JQ -r '.Common.records[2]' <<< "$JSON")
    [ "$RECORD_FIRST" = "test0" ] || return 1
    [ "$RECORD_LAST" = "test2" ] || return 1
}

test.mo.functions.MO_COMMA_IF_NOT_EMPTY() {
    local TMP
    TMP=$(mktemp -d)
    local ARRAY1=("test0" "test1" "test2")
    local ARRAY2=()
    local ARRAY3=("test3" "test4" "test5")
    local ARRAY4=()
    local ARRAY5=()
    local ARRAY6=("test6" "test7" "test8")
    cat > "$TMP/parent.json" << EOL
{
    "Common": {
        "records": [
            {{#ARRAY1}}
                {{MO_COMMA_IF_NOT_FIRST}}
                "{{.}}"
            {{/ARRAY1}}
            {{MO_COMMA_IF_NOT_EMPTY 'ARRAY1' 'ARRAY2'}}
            {{#ARRAY2}}
                {{MO_COMMA_IF_NOT_FIRST}}
                "{{.}}"
            {{/ARRAY2}}
            {{MO_COMMA_IF_NOT_EMPTY 'ARRAY1' 'ARRAY2' 'ARRAY3'}}
            {{#ARRAY3}}
                {{MO_COMMA_IF_NOT_FIRST}}
                "{{.}}"
            {{/ARRAY3}}
            {{MO_COMMA_IF_NOT_EMPTY 'ARRAY1' 'ARRAY2' 'ARRAY3' 'ARRAY4'}}
            {{#ARRAY4}}
                {{MO_COMMA_IF_NOT_FIRST}}
                "{{.}}"
            {{/ARRAY4}}
            {{MO_COMMA_IF_NOT_EMPTY 'ARRAY1' 'ARRAY2' 'ARRAY3' 'ARRAY4' 'ARRAY5'}}
            {{#ARRAY5}}
                {{MO_COMMA_IF_NOT_FIRST}}
                "{{.}}"
            {{/ARRAY5}}
            {{MO_COMMA_IF_NOT_EMPTY 'ARRAY1' 'ARRAY2' 'ARRAY3' 'ARRAY4' 'ARRAY5' 'ARRAY6'}}
            {{#ARRAY6}}
                {{MO_COMMA_IF_NOT_FIRST}}
                "{{.}}"
            {{/ARRAY6}}
        ]
    }
}
EOL
    JSON=$($RESTSH_MO -- "$TMP/parent.json")
    echo "$JSON"
    rm -rf "$TMP"
    local RECORD_FIRST RECORD_LAST
    RECORD_FIRST=$(JQ -r '.Common.records[0]' <<< "$JSON")
    RECORD_LAST=$(JQ -r '.Common.records[8]' <<< "$JSON")
    [ "$RECORD_FIRST" = "test0" ] || return 1
    [ "$RECORD_LAST" = "test8" ] || return 1
}

test.mo.functions.MO_VALUE_OR_DEFAULT.default() {
    local MO_FUNCTION_ARGS=("VALUE1" "default_value")
    local OUT
    OUT=$(MO_VALUE_OR_DEFAULT)
    [ "$OUT" = "default_value" ] || return 1
    unset MO_FUNCTION_ARGS
    unset OUT
}

test.mo.functions.MO_VALUE_OR_DEFAULT.value() {
    local MO_FUNCTION_ARGS=("VALUE1" "default_value")
    local OUT
    local VALUE1="test"
    OUT=$(MO_VALUE_OR_DEFAULT)
    [ "$OUT" = "test" ] || return 1
    unset MO_FUNCTION_ARGS
    unset OUT
}

test.mo.functions.MO_VALUE_OR_DEFAULT.json() {
    local TMP
    TMP=$(mktemp -d)
    export VALUE1="test1"
    cat > "$TMP/parent.json" << EOL
{
    "Common": {
        "key1": "{{MO_VALUE_OR_DEFAULT 'VALUE1' 'default_value'}}",
        "key2": "{{MO_VALUE_OR_DEFAULT 'VALUE2' 'default_value'}}"
    }
}
EOL
    JSON=$($RESTSH_MO -- "$TMP/parent.json")
    echo "$JSON"
    unset VALUE1
    rm -rf "$TMP"
    local RECORD_FIRST RECORD_LAST
    RECORD_FIRST=$(JQ -r '.Common.key1' <<< "$JSON")
    RECORD_LAST=$(JQ -r '.Common.key2' <<< "$JSON")
    [ "$RECORD_FIRST" = "test1" ] || return 1
    [ "$RECORD_LAST" = "default_value" ] || return 1
}

