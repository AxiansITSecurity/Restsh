# Shortdesc: Test suite for restsh.util library.
# Desc:
# Test suite for restsh.util library.

# Strict error handling
set -eEuo pipefail

test.restsh.util.echo_verbose() {
    # Usage info
    echo_verbose -h > /dev/null 2>&1 || true
    # Test
    echo_verbose "test"
    export VERBOSE=1
    echo_verbose "test"
    unset VERBOSE
}

test.restsh.util.echo_ok() {
    # Usage info
    echo_ok -h > /dev/null 2>&1 || true
    # Test
    echo_ok "test"
}

test.restsh.util.print_json_ok() {
    # Usage info
    print_json_ok -h > /dev/null 2>&1 || true
    # Test
    print_json_ok "test" | JQE ".ok.message"
}

test.restsh.util.print_json_ok_curl() {
    # Usage info
    print_json_ok_curl -h > /dev/null 2>&1 || true
    # Test
    print_json_ok_curl "test" "GET /"  | JQE ".ok | [.request, .message]"
}

test.restsh.util.echo_err() {
    # Usage info
    echo_err -h > /dev/null 2>&1 || true
    # Test
    echo_err "test"
}

test.restsh.util.print_json_err() {
    # Usage info
    print_json_err -h > /dev/null 2>&1 || true
    # Test
    print_json_err "test" 2>&1 | JQE ".error.message"
}

test.restsh.util.print_json_err_curl() {
    # Usage info
    print_json_err_curl -h > /dev/null 2>&1 || true
    # Test
    print_json_err_curl "test" "GET /" "error output" 2>&1 | JQE ".error | [.request, .message, .output]"
    print_json_err_curl "" "" "" 2>&1 | JQE ".error | [.request, .message, .output]"
}

test.restsh.util.echo_warn() {
    # Usage info
    echo_warn -h > /dev/null 2>&1 || true
    # Test
    echo_warn "test"
}

test.restsh.util.print_json_warn() {
    # Usage info
    print_json_warn -h > /dev/null 2>&1 || true
    # Test
    print_json_warn "test" 2>&1 | JQE ".warn.message"
}

test.restsh.util.print_json_warn_curl() {
    # Usage info
    print_json_warn_curl -h > /dev/null 2>&1 || true
    # Test
    print_json_warn_curl "test" "GET /" 2>&1 | JQE ".warn | [.request, .message]"
}

test.restsh.util.MO() {
    # Usage info
    MO -h > /dev/null 2>&1 || true
    # Test
    local OUTPUT
    VAR_TEST="test"
    OUTPUT=$(MO <<< '{{VAR_TEST}}')
    [ "$OUTPUT" = "$VAR_TEST" ] || return 1
}

test.restsh.util.JQ() {
    # Usage info
    JQ -h > /dev/null 2>&1 || true
    # Test
    JQ "." <<< '{"test": "test"}'
}

test.restsh.util.JQE() {
    # Usage info
    JQE -h > /dev/null 2>&1 || true
    # Test
    JQE ".test" <<< '{"test": "test"}'
    if ! JQE ".test2" <<< '{"test": "test"}'
    then 
        return 0
    fi
    return 1
}

test.restsh.util.XARGS() {
    # Usage info
    XARGS -h > /dev/null 2>&1 || true
    # Test
    echo "test1 test2" | XARGS "echo"
}

test.restsh.util.COLUMN() {
    # Usage info
    COLUMN -h > /dev/null 2>&1 || true
    # Test
    echo -e "v1\tv2\tv3\n" | COLUMN
    echo -e "v1\tv2\tv3\n" | COLUMN -N "c1,c2,c3" -o "|"
}

test.restsh.util.KV() {
    # Usage info
    KV -h > /dev/null 2>&1 || true
    # Test
    echo -e "k1\tv2\nk2\tv2" | KV
}

test.restsh.util.setcurloptions() {
    # no test suite
    return 0
}

test.restsh.util.parseoutput() {
    # Usage info
    restsh.util.parseoutput -h > /dev/null 2>&1 || true
    # Test
    restsh.util.parseoutput -f ".test" -r '{"test":"test"}'
    restsh.util.parseoutput -f ".test" '{"test":"test"}'
    restsh.util.parseoutput -r '{"test":"test"}'
    restsh.util.parseoutput '{"test":"test"}'
}

test.restsh.util.declare.var() {
    # Usage info
    restsh.util.declare.var -h > /dev/null 2>&1 || true
    # Test
    restsh.util.declare.var "KEY1=wert"
    [ "$KEY1" = "wert" ] || return 1
}

test.restsh.util.setvars() {
    # Usage info
    restsh.util.setvars -h > /dev/null 2>&1 || true
    # Test
    mkdir "$RESTSH_TMP/vars"
    echo "string" > "$RESTSH_TMP/vars/TEST_STR.txt"
    echo -e "string1\nstring2\n" > "$RESTSH_TMP/vars/TEST_ARRAY.array"
    mkdir "$RESTSH_TMP/vars/sub"
    echo "string" > "$RESTSH_TMP/vars/sub/TEST_STR2.txt"
    echo -e "string1\nstring2\n" > "$RESTSH_TMP/vars/sub/TEST_ARRAY2.array"
    touch "$RESTSH_TMP/vars/invalid-file.exe" 

    restsh.util.setvars "$RESTSH_TMP/vars"
    rm -r "$RESTSH_TMP/vars"
    [ -n "$VAR_TEST_STR" ] || return 1
    [ -n "$ARRAY_TEST_ARRAY" ] || return 1
    [ -z "${VAR_TEST_STR2+x}" ] || return 1
    [ -z "${ARRAY_TEST_ARRAY2+x}" ] || return 1
}

test.restsh.util.setvars.recursive() {
    # Usage info
    restsh.util.setvars -h > /dev/null 2>&1 || true
    # Test
    mkdir "$RESTSH_TMP/vars"
    echo "string" > "$RESTSH_TMP/vars/TEST_STR.txt"
    echo -e "string1\nstring2\n" > "$RESTSH_TMP/vars/TEST_ARRAY.array"
    mkdir "$RESTSH_TMP/vars/sub"
    echo "string" > "$RESTSH_TMP/vars/sub/TEST_STR2.txt"
    echo -e "string1\nstring2\n" > "$RESTSH_TMP/vars/sub/TEST_ARRAY2.array"

    restsh.util.setvars -r "$RESTSH_TMP/vars"
    rm -r "$RESTSH_TMP/vars"
    [ -n "$VAR_TEST_STR" ] || return 1
    [ -n "$ARRAY_TEST_ARRAY" ] || return 1
    [ -n "$VAR_TEST_STR2" ] || return 1
    [ -n "$ARRAY_TEST_ARRAY2" ] || return 1
}

test.restsh.util.setvar() {
    # Usage info
    restsh.util.setvar -h > /dev/null 2>&1 || true
    # Test
    mkdir "$RESTSH_TMP/vars"
    echo "string" > "$RESTSH_TMP/vars/TEST_STR.txt"
    echo -e "string1\nstring2\n" > "$RESTSH_TMP/vars/TEST_ARRAY.array"
    echo -e "#string1\n#string2\n" > "$RESTSH_TMP/vars/TEST_EMPTY.array"
    restsh.util.setvar "$RESTSH_TMP/vars/TEST_STR.txt"
    restsh.util.setvar "$RESTSH_TMP/vars/TEST_ARRAY.array"
    restsh.util.setvar "$RESTSH_TMP/vars/TEST_EMPTY.array"
    rm -r "$RESTSH_TMP/vars"
    [ -n "$VAR_TEST_STR" ] || return 1
    [ -n "${ARRAY_TEST_ARRAY[*]}" ] || return 1
    [ -z "${ARRAY_TEST_EMPTY[*]}" ] || return 1
    # Invalid extension
    touch "$RESTSH_TMP/vars/INVALID_EXT.txt "
    if restsh.util.setvar "$RESTSH_TMP/vars/INVALID_EXT.txt "
    then
        return 1
    fi
    # Invalid filename
    touch "$RESTSH_TMP/vars/INVALID-FILENAME.txt"
    if restsh.util.setvar "$RESTSH_TMP/vars/INVALID-FILENAME.txt"
    then
        return 1
    fi
}

test.restsh.util.urlencode() {
    # Usage info
    restsh.util.urlencode -h > /dev/null 2>&1 || true
    # Test
    local OUTPUT
    OUTPUT=$(restsh.util.urlencode "test test")
    [ "$OUTPUT" = "test%20test" ] || return 1
}

test.restsh.util.json_validate() {
    # Usage info
    restsh.util.json_validate -h > /dev/null 2>&1 || true
    # Test
    restsh.util.json_validate < test/files/valid.json
    if ! restsh.util.json_validate < test/files/invalid.json; then true; else false; fi
}

test.restsh.util.check.notempty() {
    # Usage info
    restsh.util.check.notempty -h > /dev/null 2>&1 || true
    # Test
    restsh.util.check.notempty "test"
    if ! restsh.util.check.notempty " "; then true; else false; fi
    if ! restsh.util.check.notempty "null"; then true; else false; fi
}

test.restsh.util.check.varnotempty() {
    # Usage info
    restsh.util.check.varnotempty -h > /dev/null 2>&1 || true
    # Test
    VAR1="test"
    restsh.util.check.varnotempty "VAR1"
    VAR1=""
    if ! restsh.util.check.varnotempty "VAR1"; then true; else false; fi
    VAR1=" "
    if ! restsh.util.check.varnotempty "VAR1"; then true; else false; fi
    # shellcheck disable=SC2034 # Variable is used as reference
    VAR1="null"
    if ! restsh.util.check.varnotempty "VAR1"; then true; else false; fi
    # not defined variable
    if ! restsh.util.check.varnotempty "VAR2"; then true; else false; fi
}

test.restsh.util.check.isnumber() {
    # Usage info
    restsh.util.check.isnumber -h > /dev/null 2>&1 || true
    # Test
    restsh.util.check.isnumber "10"
    if ! restsh.util.check.isnumber " 10"; then true; else false; fi
    if ! restsh.util.check.isnumber "test"; then true; else false; fi
}

test.restsh.util.check.isvarname() {
    # Usage info
    restsh.util.check.isvarname -h > /dev/null 2>&1 || true
    # Test
    restsh.util.check.isvarname "testvar"
    restsh.util.check.isvarname "TEST_VAR"
    if ! restsh.util.check.isvarname "1abc"; then true; else false; fi
    if ! restsh.util.check.isvarname " 10"; then true; else false; fi
    if ! restsh.util.check.isvarname "te-st"; then true; else false; fi
}

test.restsh.util.filesize() {
    # Usage info
    restsh.util.filesize -h > /dev/null 2>&1 || true
    # Test
    echo "test" > "$RESTSH_TMP/test"
    local OUTPUT
    OUTPUT=$(restsh.util.filesize "$RESTSH_TMP/test")
    rm -f "$RESTSH_TMP/test"
    [ "$OUTPUT" = "5" ] || return 1
}

test.restsh.util.array.includes() {
    # Usage info
    restsh.util.array.includes -h > /dev/null 2>&1 || true
    # Test
    restsh.util.array.includes "test" "test" "foo" "bar"
    restsh.util.array.includes "test" "foo" "test" "bar"
    restsh.util.array.includes "test" "foo" "bar" "test"
    if ! restsh.util.array.includes "test" "test2" "foo" "bar"; then true; else false; fi
}

test.restsh.util.array.string() {
    # Usage info
    restsh.util.array.string -h > /dev/null 2>&1 || true
    # Test
    local ARRAY=("abc" "dfg" "hij" "x y")
    local STR
    STR=$(restsh.util.array.string -q'"' "${ARRAY[@]}")
    if [ "$STR" = '"abc" "dfg" "hij" "x y"' ]; then true; else false; fi
    STR=$(restsh.util.array.string -q'"' -s, "${ARRAY[@]}")
    if [ "$STR" = '"abc","dfg","hij","x y"' ]; then true; else false; fi
    STR=$(restsh.util.array.string -s, "${ARRAY[@]}")
    if [ "$STR" = 'abc,dfg,hij,x y' ]; then true; else false; fi
    STR=$(restsh.util.array.string -p "test-" "${ARRAY[@]}")
    if [ "$STR" = 'test-abc test-dfg test-hij test-x y' ]; then true; else false; fi
}

test.restsh.util.uc() {
    # Usage info
    restsh.util.uc -h > /dev/null 2>&1 || true
    # Test
    local OUTPUT
    OUTPUT=$(restsh.util.uc "test")
    [ "$OUTPUT" = "TEST" ] || return 1
}

test.restsh.util.lc() {
    # Usage info
    restsh.util.lc -h > /dev/null 2>&1 || true
    # Test
    local OUTPUT
    OUTPUT=$(restsh.util.lc "TEST")
    [ "$OUTPUT" = "test" ] || return 1
}

test.restsh.util.askpass() {
    # Usage info
    restsh.util.askpass -h > /dev/null 2>&1 || true
    # Test
    local OUTPUT
    OUTPUT=$(restsh.util.askpass "prompt" <<< "test")
    [ "$OUTPUT" = "test" ] || return 1
}

test.restsh.util.isencrypted() {
    # Usage info
    restsh.util.isencrypted -h > /dev/null 2>&1 || true
    # Test
    restsh.util.isencrypted "AES256:test"
    if ! restsh.util.isencrypted "test"; then true; else false; fi
}

test.restsh.util.encrypt() {
    # Usage info
    restsh.util.encrypt -h > /dev/null 2>&1 || true
    # Test
    local ENCRYPTED
    local DECRYPTED
    local STR
    STR=$(restsh.pwgen)
    ENCRYPTED=$(restsh.util.encrypt <<< "$STR" | tr -d '\n')
    restsh.util.isencrypted "$ENCRYPTED"
    DECRYPTED=$(restsh.util.decrypt "$ENCRYPTED")
    [ "$STR" = "$DECRYPTED" ] || return 1
    # Negative test
    if ENCRYPTED=$(RESTSH_SECRET="" restsh.util.encrypt <<< "$STR" | tr -d '\n')
    then
        return 1
    fi
    return 0
}

test.restsh.util.var.decrypt() {
    # Usage info
    restsh.util.var.decrypt -h > /dev/null 2>&1 || true
    # Test
    local ENCRYPTED
    local STR
    STR=$(restsh.pwgen)
    ENCRYPTED=$(restsh.util.encrypt <<< "$STR" | tr -d '\n')
    restsh.util.var.decrypt ENCRYPTED
    [ "$STR" = "$ENCRYPTED" ] || return 1
    return 0
}

test.restsh.util.decrypt() {
    # Usage info
    restsh.util.decrypt -h > /dev/null 2>&1 || true
    # Test
    local ENCRYPTED
    local DECRYPTED
    local STR
    STR=$(restsh.pwgen)
    ENCRYPTED=$(restsh.util.encrypt <<< "$STR" | tr -d '\n')
    restsh.util.isencrypted "$ENCRYPTED"
    DECRYPTED=$(restsh.util.decrypt "$ENCRYPTED")
    [ "$STR" = "$DECRYPTED" ] || return 1
    # Negative test
    if restsh.util.decrypt "abc" > /dev/null 2>&1
    then
        return 1
    fi
    unset RESTSH_SECRET
    if restsh.util.decrypt "$ENCRYPTED" > /dev/null 2>&1
    then
        return 1
    fi
}

test.restsh.util.trim() {
    # Usage info
    restsh.util.trim -h > /dev/null 2>&1 || true
    # Test
    local OUTPUT
    OUTPUT=$(restsh.util.trim "  test ")
    [ "$OUTPUT" = "test" ] || return 1
}

test.restsh.util.base64url() {
    # Usage info
    restsh.util.base64url -h > /dev/null 2>&1 || true
    # Test
    local OUTPUT
    OUTPUT=$(restsh.util.base64url "test")
    [ "$OUTPUT" = "dGVzdA" ] || return 1
}

test.restsh.help() {
    if ! restsh.help > /dev/null
    then
        return 1
    fi
    for F in cert f5 f5osa gitlab scm all
    do
        if ! restsh.help "$F" > /dev/null
        then
            return 1
        fi
    done
    _restsh.help.desc.get "$RESTSH_PATH/bin/restsh/restsh.pwgen"
}

test.restsh.pwgen() {
    # Usage info
    restsh.pwgen -h > /dev/null 2>&1 || true
    # Test
    local RESULT
    RESULT=$(restsh.pwgen -c 6 -d "-" -l 20)
    [ "${#RESULT}" -eq 20 ] || return 1
    return 0
}

test.restsh.passphrase() {
    # Usage info
    restsh.passphrase -h > /dev/null 2>&1 || true
    # Test
    local RESULT
    RESULT=$(restsh.passphrase -c -n -w 8 -d "-")
    [ "${#RESULT}" -gt 15 ] || return 1
    RESULT=$(restsh.passphrase -c -n -w 8)
    [ "${#RESULT}" -gt 15 ] || return 1
    local DICT_FILE="$RESTSH_TMP/restsh.passphrase.dict"
    if [ ! -s "$DICT_FILE" ]
    then
        find /usr -type f -printf "%f\n" \
            | sed -E -e 's/\..*//' > "$DICT_FILE"
    fi
    RESULT=$(restsh.passphrase -f "$DICT_FILE")
    [ "${#RESULT}" -gt 15 ] || return 1
    return 0
}

test.restsh.util.eval_stage_var() {
    # Usage info
    restsh.util.eval_stage_var -h > /dev/null 2>&1 || true
    # Test
    EXAMPLE_DEV="test"
    restsh.util.eval_stage_var "EXAMPLE" "DEV"
    [ "$EXAMPLE" = "$EXAMPLE_DEV" ] || return 1
}

# shellcheck disable=SC2034 # Array is used in test.sh
TESTS_RESTSH_UTIL=(
    test.restsh.util.echo_ok
    test.restsh.util.echo_verbose
    test.restsh.util.print_json_ok
