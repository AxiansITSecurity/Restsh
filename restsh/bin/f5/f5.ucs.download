# https://github.com/AxiansITSecurity/Restsh

# Shortdesc: Manages ucs on the F5, /var/local/ucs/.
# Desc:
# Manages ucs on the F5, /var/local/ucs/.
# https://community.f5.com/t5/technical-forum/using-an-asynchronous-task-creating-ucs-file/td-p/272613

# Strict error handling
set -eEu -o pipefail

# Debug mode
[ -n "${RESTSH_DEBUG+x}" ] && set -x

if [ -z "${RESTSH_PATH+x}" ]
then
    echo "Script must be run in the restsh environment."
    exit 1
fi

while getopts ':h' OPTION
do
    case "$OPTION" in
        *) OPTION="invalid"; break ;;
    esac
done
shift "$((OPTIND -1))"

if [ "$OPTION" = "invalid" ] || [ -z "${1+x}" ] || [ -z "${2+x}" ]
then
    exec 1>&2
    _restsh.help.desc.get "$0"
    echo "Usage: $(basename "$0") <name> <local file>"
    exit 2
fi

restsh.util.check.string "name" "$1"; NAME=$1
restsh.util.check.string "local file" "$2"; LOCAL_FILE=$2

f5.file.download "/mgmt/shared/file-transfer/ucs-downloads" "$NAME" 0 "$LOCAL_FILE"
