#!/usr/bin/env bash

# Author: Juergen Mang <juergen.mang@axians.de>
# Date: 2024-05-02

# Shortdesc: Adds a disallowed filetype to a F5 ASM Policy.
# Desc:
# Adds a disallowed filetype to a F5 ASM Policy.

# Strict error handling
set -eEu -o pipefail

# Debug mode
[ -n "${RESTSH_DEBUG+x}" ] && set -x

if [ -z "${RESTSH_PATH+x}" ]
then
    echo "Script must be run in the restsh environment."
    exit 1
fi

if [ -z "${1+x}" ] || [ -z "${2+x}" ]
then
    restsh.help.shortdesc.get "$0"
    echo "Usage:"
    echo "$(basename "$0") <policy full path> <filetype>"
    echo ""
    echo "Template for add is: $MODIFY_TEMPLATE"
    echo "Defaults for add are:"
    sed -E 's/.*&& (.*)/\t\1/' "$RESTSH_PATH/$MODIFY_DEFAULTS"
fi

POLICY=$1
FILETYPE=$2

ENTITY="filetypes"
MODIFY_TEMPLATE="templates/f5/asm/entity.filetypes-disallowed.json"
MODIFY_DEFAULTS="templates/f5/asm/entity.filetypes-disallowed.var"

export VAR_DISALLOWED_FILETYPE=$FILETYPE
if ! RESULT=$(f5.asm.entity.add "$POLICY" "$RESTSH_PATH/$MODIFY_TEMPLATE" "$RESTSH_PATH/$MODIFY_DEFAULTS" "$ENTITY")
then
    echo_err "Failed"
    echo_err "$RESULT"
    exit 1
fi

exit 0
