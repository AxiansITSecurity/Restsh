#!/usr/bin/env bash

# Author: Juergen Mang <juergen.mang@axians.de>
# Date: 2024-08-02

# Shortdesc: Lists traffic management certificates on the F5.
# Desc:
# Lists traffic management certificates on the F5.

# Strict error handling
set -eEu -o pipefail

# Debug mode
[ -n "${RESTSH_DEBUG+x}" ] && set -x

if [ -z "${RESTSH_PATH+x}" ]
then
    echo "Script must be run in the restsh environment."
    exit 1
fi

# Get options
RAW=0
while getopts ':r' OPTION
do
    case "$OPTION" in
        r) RAW=1 ;;
        *) OPTION="invalid"; break ;;
    esac
done
shift "$((OPTIND -1))"

if [ "$OPTION" = "invalid" ]
then
    exec 1>&2
    _restsh.help.shortdesc.get "$0"
    echo "Usage: $(basename "$0") [-r]"
    echo -e "\tUse -r for raw output."
    exit 2
fi

CERTLIST=$(GET "/mgmt/tm/sys/file/ssl-cert")

if [ "$RAW" -eq 1 ]
then
    echo "$CERTLIST"
    exit 0
fi

NEXTMONTH=$(date -d "next month" +%s)
NOW=$(date +%s)

{
    for F in $(JQ -r ".items | .[].fullPath" <<< "$CERTLIST")
    do
        EXPIRATION=$(JQ -r ".items | .[] | select(.fullPath==\"$F\") | .expirationDate" <<< "$CERTLIST")
        EXP_FRIENDLY=$(date -d @"$EXPIRATION")
        if  [ "$EXPIRATION" -lt "$NOW" ]
        then
            echo -e "$F\texpired\t$EXP_FRIENDLY"
        elif [ "$EXPIRATION" -lt "$NEXTMONTH" ]
        then
            echo -e "$F\texpires soon\t$EXP_FRIENDLY"
        else
            echo -e "$F\tok\t$EXP_FRIENDLY"
        fi
    done
} | COLUMN -o "|" -N "Certificate,State,Expiration"
