#!/usr/bin/env bash

# Author: Juergen Mang <juergen.mang@axians.de>
# Date: 2023-08-07

# Shortdesc: Manages QKViews on the F5.
# Desc:
# Manages QKViews on the F5.
# https://my.f5.com/manage/s/article/K04396542

# Strict error handling
set -eEu -o pipefail

# Debug mode
[ -n "${RESTSH_DEBUG+x}" ] && set -x

if [ -z "${RESTSH_PATH+x}" ]
then
    echo "Script must be run in the restsh environment."
    exit 1
fi

# Get options
RAW=0
while getopts ':r' OPTION
do
    case "$OPTION" in
        r) RAW=1 ;;
        *) OPTION="invalid"; break ;;
    esac
done
shift "$((OPTIND -1))"

if [ "$OPTION" = "invalid" ]
then
    exec 1>&2
    _restsh.help.desc.get "$0"
    echo "Usage: $(basename "$0") [-r]"
    echo -e "\tUse -r for raw output."
    exit 2
fi

if [ "$RAW" -eq 1 ]
then
    GET -r "/mgmt/cm/autodeploy/qkview" \
        | $RESTSH_JQ -r ".items[] | [.name,.status,.id]"
else
    GET -r "/mgmt/cm/autodeploy/qkview" \
        | $RESTSH_JQ -r ".items[] | [.name,.status,.id] | @tsv" \
        | COLUMN -o "|" -N "Name,Status,Id"
fi
