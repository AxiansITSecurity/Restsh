#!/usr/bin/env bash

# Author: Juergen Mang <juergen.mang@axians.de>
# Date: 2024-06-12

# Shortdesc: Imports a F5 ASM Policy in binary or xml format.
# Desc:
# Imports a F5 ASM Policy in binary or xml format.

# Strict error handling
set -eEu -o pipefail

# Debug mode
[ -n "${RESTSH_DEBUG+x}" ] && set -x

if [ -z "${RESTSH_PATH+x}" ]
then
    echo "Script must be run in the restsh environment."
    exit 1
fi

if [ -z "${1+x}" ] || [ -z "${2+x}" ]
then
    exec 1>&2
    _restsh.help.shortdesc.get "$0"
    echo "Usage: $(basename "$0") <filename> <policy name>"
    exit 2
fi

FILENAME=$1
NAME=$2

# Upload the policy file
f5.file-transfer.upload "$FILENAME"

FILENAME=$(basename "$FILENAME")
f5.run "mv /var/config/rest/downloads/$FILENAME /ts/var/rest/${RESTSH_USER}~$FILENAME"

# Start import task
TASK_ID=$($RESTSH_JQ -n --arg name "$NAME" \
    --arg filename "$FILENAME" \
    '{
        "name": $name,
        "filename": $filename
    }' | POST "/mgmt/tm/asm/tasks/import-policy?\$select=id" | \
        $RESTSH_JQ -r ".id")

if [ -z "${TASK_ID}" ]
then
    echo_err "Import of policy \"$NAME\" failed."
    exit 1
fi

# Wait for completed task
if ! f5.asm.taskwait import-policy "$TASK_ID"
then
    echo_err "Import of policy failed."
    exit 1
fi
