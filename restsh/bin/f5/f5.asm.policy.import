#!/usr/bin/env bash

# SPDX-License-Identifier: GPL-3.0-or-later
# (c) Axians IT Security GmbH
# Jürgen Mang <juergen.mang@sec.axians.de>
# https://www.axians.de/security
# https://github.com/AxiansITSecurity/Restsh

# Shortdesc: Imports a F5 ASM Policy in json, binary or xml format.
# Desc:
# Imports a F5 ASM Policy in json, binary or xml format.

# Strict error handling
set -eEu -o pipefail

# Debug mode
[ -n "${RESTSH_DEBUG+x}" ] && set -x

if [ -z "${RESTSH_PATH+x}" ]
then
    echo "Script must be run in the restsh environment."
    exit 1
fi

OPENAPI_FILE=""
ENFORCE_SIGNATURES=0
APPLY_POLICY=1
IMPORT=0
while getopts ':ehino:' OPTION
do
    case "$OPTION" in
        e) ENFORCE_SIGNATURES=1 ;;
        i) IMPORT=1 ;;
        n) APPLY_POLICY=0 ;;
        o) OPENAPI_FILE="$OPTARG" ;;
        *) OPTION="invalid"; break ;;
    esac
done
shift "$((OPTIND -1))"

if [ "$OPTION" = "invalid" ] || [ -z "${1+x}" ] || [ -z "${2+x}" ]
then
    exec 1>&2
    _restsh.help.desc.get "$0"
    echo "Usage: $(basename "$0") [options...] <filename> <policy fullPath>"
    echo "    -e                 Enforce all signatures"
    echo "    -i                 Enforce given policy path (Overwrite fullPath in import file)"
    echo "    -n                 Do not apply policy after import"
    echo "    -o <openapi file>  Specify OpenApi File"
    exit 2
fi

restsh.util.check.string "filename" "$1"; FILENAME=$1
restsh.util.check.string "policy fullPath" "$2"; FULL_PATH=$2

# Upload the policy file
if f5.file-transfer.upload "$FILENAME" > /dev/null
then
    FILENAME=$(basename "$FILENAME")
    f5.run "mv" "/var/config/rest/downloads/$FILENAME" "/ts/var/rest/${RESTSH_USER}~$FILENAME"
    echo_ok "Uploaded $FILENAME to /ts/var/rest/"
else
    echo_err "Failure uploading $FILENAME"
fi

# Optionally upload the openapi file
if [ -n "$OPENAPI_FILE" ]
then
    if f5.file-transfer.upload "$OPENAPI_FILE" > /dev/null
    then
        OPENAPI_FILE=$(basename "$OPENAPI_FILE")
        f5.run "mv" "/var/config/rest/downloads/$OPENAPI_FILE" "/ts/var/rest/${RESTSH_USER}~$OPENAPI_FILE"
        echo_ok "Uploaded $OPENAPI_FILE to /ts/var/rest/"
    else
        echo_err "Failure uploading $FILENAME"
    fi
fi

if [ "$IMPORT" -eq 0 ]
then
    PAYLOAD=$($RESTSH_JQ -n --arg name "$FULL_PATH" \
        --arg filename "$FILENAME" \
        '{
            "filename": $filename,
            "policy":{
                "fullPath": $name
            }
        }')
else
    PAYLOAD=$($RESTSH_JQ -n --arg name "$FULL_PATH" \
        --arg filename "$FILENAME" \
        '{
            "name": $name,
            "filename": $filename
        }')
fi

# Start import task
TASK_ID=$(POST "/mgmt/tm/asm/tasks/import-policy?\$select=id" <<< "$PAYLOAD" \
       | JQE -r ".id")

if ! restsh.util.check.notempty "${TASK_ID}"
then
    echo_err "Import of policy \"$FULL_PATHE\" failed."
    exit 1
fi

# Wait for completed task
if ! f5.asm.taskwait import-policy "$TASK_ID"
then
    echo_err "Import of policy failed."
    exit 1
fi
echo_ok "Import of policy was successful"

# Cleanup
f5.file.remove "/ts/var/rest/${RESTSH_USER}~$FILENAME" > /dev/null
[ -n "$OPENAPI_FILE" ] && f5.file.remove "/ts/var/rest/${RESTSH_USER}~$OPENAPI_FILE" > /dev/null

if [ "$ENFORCE_SIGNATURES" -eq 1 ]
then
    # Enforce signatures and apply the policy
    f5.asm.signaturestaging.enforce -n -a "$FULL_PATH"
fi

if [ "$APPLY_POLICY" -eq 1 ]
then
    # Apply the policy
    f5.asm.policy.apply "$FULL_PATH"
fi
