# (c) Axians IT Security GmbH
# Jürgen Mang <juergen.mang@sec.axians.de>
# https://www.axians.de/security

# Shortdesc: Downloads a F5 software image, directory: /shared/images/.
# Desc:
# Downloads a F5 software image, directory: /shared/images/.

# Strict error handling
set -eEu -o pipefail

# Debug mode
[ -n "${RESTSH_DEBUG+x}" ] && set -x

if [ -z "${RESTSH_PATH+x}" ]
then
    echo "Script must be run in the restsh environment."
    exit 1
fi

while getopts ':h' OPTION
do
    case "$OPTION" in
        *) OPTION="invalid"; break ;;
    esac
done
shift "$((OPTIND -1))"

if [ "$OPTION" = "invalid" ] || [ $# -lt 2 ]
then
    exec 1>&2
    _restsh.help.desc.get "$0"
    echo "Usage: $(basename "$0") <file> <output file>"
    exit 2
fi

restsh.util.check.string "file" "$1";
restsh.util.check.string "output file" "$2";

f5.file.download "/mgmt/cm/autodeploy/software-image-downloads" "$1" 0 "$2"
