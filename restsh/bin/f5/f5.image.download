#!/usr/bin/env bash

# Author: Juergen Mang <juergen.mang@axians.de>
# Date: 2024-05-02

# Shortdesc: Downloads a F5 software image, directory: /shared/images/.
# Desc:
# Downloads a F5 software image, directory: /shared/images/.

# Strict error handling
set -eEu -o pipefail

# Debug mode
[ -n "${RESTSH_DEBUG+x}" ] && set -x

if [ -z "${RESTSH_PATH+x}" ]
then
    echo "Script must be run in the restsh environment."
    exit 1
fi

if [ $# -lt 2 ]
then
    exec 1>&2
    restsh.help.shortdesc.get "$0"
    echo "Usage: $(basename "$0") <file> <output file>"
fi

f5.file.download "/mgmt/cm/autodeploy/software-image-downloads" "$1" 0 "$2"
exit 0
