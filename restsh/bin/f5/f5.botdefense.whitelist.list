#!/usr/bin/env bash

# (c) Axians IT Security GmbH
# Jürgen Mang <juergen.mang@sec.axians.de>
# https://www.axians.de/security

# Shortdesc: Lists all Whitelist Entries for a F5 Bot Defense Profile.
# Desc:
# Lists all Whitelist Entries for a F5 Bot Defense Profile.

# Strict error handling
set -eEu -o pipefail

# Debug mode
[ -n "${RESTSH_DEBUG+x}" ] && set -x

if [ -z "${RESTSH_PATH+x}" ]
then
    echo "Script must be run in the restsh environment."
    exit 1
fi

# Get options
RAW=0
GET_OPTS=("-r")
while getopts ':r' OPTION
do
    case "$OPTION" in
        r) RAW=1 ;;
        *) OPTION="invalid"; break ;;
    esac
done
shift "$((OPTIND -1))"

if [ "$OPTION" == "invalid" ] || [ $# -lt 1 ]
then
    exec 1>&2
    _restsh.help.desc.get "$0"
    echo "Usage: $(basename "$0") [options...] <fullPath>"
    echo "    -r  Raw output."
    exit 2
fi

restsh.util.check.string "fullPath" "$1"; FULLPATH=${1//\//\~}

# Main
if RESULT=$(GET "${GET_OPTS[@]}" "/mgmt/tm/security/bot-defense/profile/$FULLPATH/whitelist")
then
    if [ "$RAW" -eq 1 ]
    then
        JQ "." <<< "$RESULT"
    else
        JQ -r '.items[] | [.name, .sourceAddress, .url, .matchOrder] | @tsv' <<< "$RESULT" | \
            COLUMN -o "|" -N "Name,Source Address,URL,Match Order"
    fi
    exit 0
fi

exit 1
