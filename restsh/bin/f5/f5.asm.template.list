# https://github.com/AxiansITSecurity/Restsh

# Shortdesc: Lists all F5 ASM Policy Templates.
# Desc:
# Lists all F5 ASM Policy Templates.

# Strict error handling
set -eEu -o pipefail

# Debug mode
[ -n "${RESTSH_DEBUG+x}" ] && set -x

if [ -z "${RESTSH_PATH+x}" ]
then
    echo "Script must be run in the restsh environment."
    exit 1
fi

# Get options
RAW=0
USER_DEFINED=0
while getopts ':ru' OPTION
do
    case "$OPTION" in
        r) RAW=1 ;;
        u) USER_DEFINED=1 ;;
        *) OPTION="invalid"; break ;;
    esac
done
shift "$((OPTIND -1))"

if [ "$OPTION" == "invalid" ]
then
    exec 1>&2
    _restsh.help.desc.get "$0"
    echo "Usage: $(basename "$0") [-r] [-u]"
    echo "Options:"
    echo "    -r  Raw output."
    echo "    -u  Show user defined templates only."
    exit 2
fi

FILTER=""
[ "$USER_DEFINED" -eq 1 ] && FILTER="&\$filter=templateType%20eq%20user-defined"

# Main
if RESULT=$(GET "/mgmt/tm/asm/policy-templates?\$select=title,name,id,description,user-defined${FILTER}")
then
    if [ "$RAW" -eq 1 ]
    then
        echo "$RESULT"
    else
        $RESTSH_JQ -r '.items[] | [.title, .name, .id, .description] | @tsv' <<< "$RESULT" | \
            COLUMN -o "|" -N "title,name,id,description"
    fi
    exit 0
fi

exit 1
