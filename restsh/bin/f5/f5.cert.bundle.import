#!/usr/bin/env bash

# (c) Axians IT Security GmbH
# Jürgen Mang <juergen.mang@sec.axians.de>
# https://www.axians.de/security

# Shortdesc: Imports traffic management key + cert + optional chain file.
# Desc:
# Imports traffic management key + cert + optional chain file.

# Strict error handling
set -eEu -o pipefail

# Debug mode
[ -n "${RESTSH_DEBUG+x}" ] && set -x

if [ -z "${RESTSH_PATH+x}" ]
then
    echo "Script must be run in the restsh environment."
    exit 1
fi

DATE_SUFFIX=1
BUNDLE_NAME=""
while getopts ':hns:' OPTION
do
    case "$OPTION" in
        n) DATE_SUFFIX=0 ;;
        s) restsh.util.check.string "bundle name" "$OPTARG"; BUNDLE_NAME="$OPTARG" ;;
        *) OPTION="invalid"; break ;;
    esac
done
shift "$((OPTIND -1))"

if [ "$OPTION" = "invalid" ] || [ $# -lt 2 ]
then
    exec 1>&2
    _restsh.help.desc.get "$0"
    echo "Usage: $(basename "$0") [options...] <key> <cert> [<chain bundle>]"
    echo "Options:"
    echo "    -s <name>  Set the name of the bundle, default: FQDN"
    echo "    -n         Do not add date suffix"
    exit 2
fi

restsh.util.check.string "key" "$1"; FILE_KEY=$1
restsh.util.check.string "cert" "$2"; FILE_CERT=$2
FILE_BUNDLE=""
if [ -n "${3+x}" ]
then
    restsh.util.check.string "chain bundle" "$3"; FILE_BUNDLE=$3
fi

CN=$(openssl x509 -in "$FILE_CERT" -noout -subject -nameopt compat | sed -r -e 's|.*CN=([^/]+).*|\1|' -e 's|^\*|wildcard|')
if [ -z "$BUNDLE_NAME" ]
then
    BUNDLE_NAME="$CN"
fi

if [ "$DATE_SUFFIX" -eq 1 ]
then
    STARTDATE_TS=$(date +%s --date="$(openssl x509 -in "$FILE_CERT" -noout -startdate | cut -d= -f2)")
    STARTDATE=$(date +%Y-%m --date=@"${STARTDATE_TS}")
    BUNDLE_NAME="${BUNDLE_NAME}_${STARTDATE}"
fi

echo "Importing cert bundle $BUNDLE_NAME"

f5.cert.import "$BUNDLE_NAME" "$FILE_CERT"
f5.cert.key.import "$BUNDLE_NAME" "$FILE_KEY"
if [ -n "$FILE_BUNDLE" ]
then
    f5.cert.import "${BUNDLE_NAME}_cabundle" "$FILE_BUNDLE"
fi
