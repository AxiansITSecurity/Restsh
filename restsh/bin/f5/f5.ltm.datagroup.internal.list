# Shortdesc: Lists internal datagroups.
# Desc:
# Lists internal datagroups.

# Strict error handling
set -eEu -o pipefail

# Debug mode
[ -n "${RESTSH_DEBUG+x}" ] && set -x

if [ -z "${RESTSH_PATH+x}" ]
then
  echo "Script must be run in the restsh environment."
  exit 1
fi

RAW="0"
while getopts ':hr' OPTION
do
    case "$OPTION" in
        r) RAW=1 ;;
        *) OPTION="invalid"; break ;;
    esac
done
shift "$((OPTIND -1))"

if [ "$OPTION" = "invalid" ]
then
    exec 1>&2
    _restsh.help.desc.get "$0"
    echo "Usage: $(basename "$0")"
    exit 2
fi

if [ "$RAW" -eq 1 ]
then
    GET "/mgmt/tm/ltm/data-group/internal?\$select=fullPath"
else
    GET "/mgmt/tm/ltm/data-group/internal?\$select=fullPath" | JQ -r ".items[].fullPath"
fi
