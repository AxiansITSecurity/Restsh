# Shortdesc: Modifies a System Variable.
# Desc:
# Modifies a System Variable.

# Strict error handling
set -eEu -o pipefail

# Debug mode
[ -n "${RESTSH_DEBUG+x}" ] && set -x

if [ -z "${RESTSH_PATH+x}" ]
then
    echo "Script must be run in the restsh environment."
    exit 1
fi

RAW=0
while getopts ':hr' OPTION
do
    case "$OPTION" in
        r) RAW=1 ;;
        *) OPTION="invalid"; break ;;
    esac
done
shift "$((OPTIND -1))"

if [ "$OPTION" = "invalid" ] || [ -z "${1+x}" ] || [ -z "${2+x}" ]
then
    exec 1>&2
    _restsh.help.desc.get "$0"
    echo "Usage: $(basename "$0") <name> <value>"
    exit 2
fi

restsh.util.check.string "name" "$1"; NAME=$(restsh.util.urlencode "$1")
restsh.util.check.string "value" "$2"; VALUE=$2

# Main
RESULT=$(JQ -n --arg value "$VALUE" \
    '{
        value: $value
    }' | PATCH "/mgmt/tm/sys/db/$NAME")

if [ "$RAW" -eq 1 ]
then
    JQ "." <<< "$RESULT"
else
    JQE -r '[.name, .value] | @tsv' <<< "$RESULT" | KV
fi
