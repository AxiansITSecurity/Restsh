#!/usr/bin/env bash

# Author: Juergen Mang <juergen.mang@axians.de>
# Date: 2025-10-02

# Shortdesc: Lists snmp v3 users.
# Desc:
# Lists snmp v3 users.

# Strict error handling
set -eEu -o pipefail

# Debug mode
[ -n "${RESTSH_DEBUG+x}" ] && set -x

if [ -z "${RESTSH_PATH+x}" ]
then
    echo "Script must be run in the restsh environment."
    exit 1
fi

RAW=0
while getopts ':hr' OPTION
do
    case "$OPTION" in
        r) RAW=1 ;;
        *) OPTION="invalid"; break ;;
    esac
done
shift "$((OPTIND -1))"

if [ "$OPTION" = "invalid" ]
then
    exec 1>&2
    _restsh.help.desc.get "$0"
    echo "Usage: $(basename "$0") [-r]"
    echo "    -r  Raw output."
    exit 2
fi

if [ "$RAW" -eq 1 ]
then
    GET /mgmt/tm/sys/snmp/users
else
    GET /mgmt/tm/sys/snmp/users | JQ -r '.items[] | [.fullPath, .username, .access, .oidSubset] | @tsv' \
        | COLUMN -o "|" -N "fullPath,username,access,oidSubset"
fi
