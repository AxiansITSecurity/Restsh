#!/usr/bin/env bash

# Author: Juergen Mang <juergen.mang@axians.de>
# Date: 2024-12-17

# Shortdesc: Lists all F5 ASM Policies.
# Desc:
# Lists all F5 ASM Polices.

# Strict error handling
set -eEu -o pipefail

# Debug mode
[ -n "${RESTSH_DEBUG+x}" ] && set -x

if [ -z "${RESTSH_PATH+x}" ]
then
    echo "Script must be run in the restsh environment."
    exit 1
fi

# Get options
RAW=0
GET_OPTS=("-r")
while getopts ':f:r' OPTION
do
    case "$OPTION" in
        f) GET_OPTS+=("-f" "$OPTARG") ;;
        r) RAW=1 ;;
        *) OPTION="invalid"; break ;;
    esac
done
shift "$((OPTIND -1))"

if [ "$OPTION" == "invalid" ]
then
    exec 1>&2
    _restsh.help.desc.get "$0"
    echo "Usage: $(basename "$0") [options...]"
    echo "    -f <filter>  Filter output with jq."
    echo "    -r           Raw output."
    exit 2
fi

# Main
if RESULT=$(GET "${GET_OPTS[@]}" "/mgmt/tm/asm/policies?\$select=fullPath,isModified,parentPolicyName,id,enforcementMode,description")
then
    if [ "$RAW" -eq 1 ]
    then
        echo "$RESULT"
    else
        $RESTSH_JQ -r '.items[] | [.fullPath, .isModified, .enforcementMode, .id] | @tsv' <<< "$RESULT" | \
            COLUMN -o "|" -N "fullPath,Modified,enforcementMode,id"
    fi
    exit 0
fi

exit 1
