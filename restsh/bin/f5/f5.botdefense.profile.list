#!/usr/bin/env bash

# Author: Juergen Mang <juergen.mang@axians.de>
# Date: 2025-05-16

# Shortdesc: Lists all F5 Bot Defense Profiles.
# Desc:
# Lists all F5 Bot Defense Profiles.

# Strict error handling
set -eEu -o pipefail

# Debug mode
[ -n "${RESTSH_DEBUG+x}" ] && set -x

if [ -z "${RESTSH_PATH+x}" ]
then
    echo "Script must be run in the restsh environment."
    exit 1
fi

# Get options
RAW=0
GET_OPTS=("-r")
while getopts ':r' OPTION
do
    case "$OPTION" in
        r) RAW=1 ;;
        *) OPTION="invalid"; break ;;
    esac
done
shift "$((OPTIND -1))"

if [ "$OPTION" == "invalid" ]
then
    exec 1>&2
    _restsh.help.desc.get "$0"
    echo "Usage: $(basename "$0") [options...]"
    echo "    -r  Raw output."
    exit 2
fi

# Main
if RESULT=$(GET "${GET_OPTS[@]}" "/mgmt/tm/security/bot-defense/profile/")
then
    if [ "$RAW" -eq 1 ]
    then
        JQ "." <<< "$RESULT"
    else
        JQ -r '.items[] | [.fullPath, .template, .enforcementMode] | @tsv' <<< "$RESULT" | \
            COLUMN -o "|" -N "fullPath,Template,enforcementMode"
    fi
    exit 0
fi

exit 1
