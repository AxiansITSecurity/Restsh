#!/usr/bin/env bash

# (c) Axians IT Security GmbH
# Jürgen Mang <juergen.mang@sec.axians.de>
# https://www.axians.de/security

# Shortdesc: Lists ha-groups.
# Desc:
# Lists ha-groups.

# Strict error handling
set -eEu -o pipefail

# Debug mode
[ -n "${RESTSH_DEBUG+x}" ] && set -x

if [ -z "${RESTSH_PATH+x}" ]
then
    echo "Script must be run in the restsh environment."
    exit 1
fi

RAW=0
while getopts ':r' OPTION
do
    case "$OPTION" in
        r) RAW=1 ;;
        *) OPTION="invalid"; break ;;
    esac
done
shift "$((OPTIND -1))"

if [ "$OPTION" = "invalid" ]
then
    exec 1>&2
    _restsh.help.desc.get "$0"
    echo "Usage:"
    echo "$(basename "$0") [options...]"
    echo "Options:"
    echo "    -r Raw output"
    exit 2
fi

if [ "$RAW" -eq 1 ]
then
    GET "/mgmt/tm/sys/ha-group"
else
    GET -r "/mgmt/tm/sys/ha-group" | JQ -r '.items[] | [.name,.enabled,.activeBonus] | @tsv ' \
        | COLUMN -o "|" -N "name,enabled,activeBonus"
fi
