#!/usr/bin/env bash

# Author: Juergen Mang <juergen.mang@axians.de>
# Date: 2023-07-27

# Shortdesc: Lists all AS3 Tenants.
# Desc:
# Lists all AS3 Tenants.

# Strict error handling
set -eEu -o pipefail

# Debug mode
[ -n "${RESTSH_DEBUG+x}" ] && set -x

if [ -z "${RESTSH_PATH+x}" ]
then
    echo "Script must be run in the restsh environment."
    exit 1
fi

# Get options
RAW=0
while getopts ':r' OPTION
do
    case "$OPTION" in
        r) RAW=1 ;;
        *) OPTION="invalid"; break ;;
    esac
done
shift "$((OPTIND -1))"

if [ "$OPTION" == "invalid" ]
then
    exec 1>&2
    _restsh.help.desc.get "$0"
    echo "Usage: $(basename "$0") [-r]"
    echo -e "\tUse -r for raw output."
    exit 2
fi

# Main
if RESULT=$(GET "/mgmt/shared/appsvcs/declare/?filterClass=Tenant")
then
    if [ "$RAW" -eq 1 ]
    then
        echo "$RESULT"
    else
        $RESTSH_JQ -r 'keys[]' <<< "$RESULT"
    fi
    exit 0
fi

exit 1