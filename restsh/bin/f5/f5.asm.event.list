#!/usr/bin/env bash

# Author: Juergen Mang <juergen.mang@axians.de>
# Date: 2025-06-26

# Shortdesc: Lists ASM Events.
# Desc:
# Lists ASM Events.

# Strict error handling
set -eEu -o pipefail

# Debug mode
[ -n "${RESTSH_DEBUG+x}" ] && set -x

if [ -z "${RESTSH_PATH+x}" ]
then
  echo "Script must be run in the restsh environment."
  exit 1
fi

RAW=0
POLICY=""
while getopts ':hp:r' OPTION
do
    case "$OPTION" in
        p) POLICY=$OPTARG ;;
        r) RAW=1 ;;
        *) OPTION="invalid"; break ;;
    esac
done
shift "$((OPTIND -1))"

if [ "$OPTION" = "invalid" ]
then
    exec 1>&2
    _restsh.help.desc.get "$0"
    echo "Usage: $(basename "$0") [options...]"
    echo "    -p           ASM Policy Full Path."
    echo "    -r           Raw output."
    exit 2
fi

if [ -n "$POLICY" ]
then
    FILTER=".items[] | select(.requestPolicyReference.fullPath == \"$POLICY\")"
else
    FILTER=""
fi

if RESULT=$(GET -f "$FILTER" "/mgmt/tm/asm/events/requests")
then
    if [ "$RAW" -eq 1 ]
    then
         JQ "." <<< "$RESULT"
    else
        JQ -r "[.id,.url,.requestDatetime] | @tsv" <<< "$RESULT" \
            | COLUMN -o "|" -N "id,url,requestDatetime"
    fi
    exit 0
fi
exit 1
