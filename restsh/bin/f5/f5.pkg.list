#!/usr/bin/env bash

# Author: Juergen Mang <juergen.mang@axians.de>
# Date: 2025-03-27

# Shortdesc: Lists all installed iAPPs LX Packages.
# Desc:
# Lists all installed iAPPs LX Packages.

# Strict error handling
set -eEu -o pipefail

# Debug mode
[ -n "${RESTSH_DEBUG+x}" ] && set -x

if [ -z "${RESTSH_PATH+x}" ]
then
    echo "Script must be run in the restsh environment."
    exit 1
fi

RAW=0
while getopts ':hr' OPTION
do
    case "$OPTION" in
        r) RAW=1 ;;
        *) OPTION="invalid"; break ;;
    esac
done
shift "$((OPTIND -1))"

if [ "$OPTION" = "invalid" ]
then
    exec 1>&1
    _restsh.help.desc.get "$0"
    echo "Usage: $(basename "$0")"
    exit 2
fi

if ! TASK_ID=$(JQ -n \
    '{
        "operation": "QUERY"
    }' | POST "/mgmt/shared/iapp/package-management-tasks" | JQ -r ".id")
then
    echo_err "Posting query command failed."
    exit 1
fi

# Wait for completed task
if ! f5.pkg.taskwait "$TASK_ID"
then
    exit 1
fi

RESULT=$(GET "/mgmt/shared/iapp/package-management-tasks/$TASK_ID")

if [ "$RAW" -eq 1 ]
then
    JQ "." <<< "$RESULT"
else
    JQ -r '.queryResponse[] | [.packageName,.tags[0]] | @tsv' <<< "$RESULT" \
        | COLUMN -o "|" -N "packageName,Tags"
fi
