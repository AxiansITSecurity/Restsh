#!/usr/bin/env bash

# (c) Axians IT Security GmbH
# Jürgen Mang <juergen.mang@sec.axians.de>
# https://www.axians.de/security

# Shortdesc: Lists CSRs on the F5.
# Desc:
# Lists CSRs on the F5.

# Strict error handling
set -eEu -o pipefail

# Debug mode
[ -n "${RESTSH_DEBUG+x}" ] && set -x

if [ -z "${RESTSH_PATH+x}" ]
then
    echo "Script must be run in the restsh environment."
    exit 1
fi

# Get options
RAW=0
while getopts ':r' OPTION
do
    case "$OPTION" in
        r) RAW=1 ;;
        *) OPTION="invalid"; break ;;
    esac
done
shift "$((OPTIND -1))"

if [ "$OPTION" = "invalid" ]
then
    exec 1>&2
    _restsh.help.desc.get "$0"
    echo "Usage: $(basename "$0") [options...]"
    echo "Options:"
    echo "-r  Raw output."
    exit 2
fi

if [ "$RAW" -eq 1 ]
then
    GET "/mgmt/tm/sys/crypto/csr"
else
    {
        while IFS=$'\t' read -r CSR NAME
        do
            printf "%s\t%s\n" "$CSR" "$NAME"
        done < <(GET -r "/mgmt/tm/sys/crypto/csr" | JQ -r '.items[] | [.name, .commonName] | @tsv')
    } | COLUMN -o "|" -N "CSR,commonName"
fi
