#!/usr/bin/env bash

# (c) Axians IT Security GmbH
# Jürgen Mang <juergen.mang@sec.axians.de>
# https://www.axians.de/security

# Shortdesc: Imports and optionally uploads a pkcs12 file.
# Desc:
# Imports and optionally uploads a pkcs12 file.

# Strict error handling
set -eEu -o pipefail

# Debug mode
[ -n "${RESTSH_DEBUG+x}" ] && set -x

if [ -z "${RESTSH_PATH+x}" ]
then
    echo "Script must be run in the restsh environment."
    exit 1
fi

UPLOAD=0
while getopts ':hu' OPTION
do
    case "$OPTION" in
        u) UPLOAD=1 ;;
        *) OPTION="invalid"; break ;;
    esac
done
shift "$((OPTIND -1))"

if [ "$OPTION" = "invalid" ] || [ $# -lt 2 ]
then
    exec 1>&2
    _restsh.help.desc.get "$0"
    echo "Usage: $(basename "$0") [options...] <pkcs12 file> <name> <password>"
    echo "Options:"
    echo "    -u  Upload pkcs12 before import."
    exit 2
fi

PKCS12_FILE=$1
NAME=$2
PASSWORD=$3

remove_upload_file() {
    if [ "$UPLOAD" -eq 1 ]
    then
        f5.file-transfer.remove "$(basename "$PKCS12_FILE")" > /dev/null
    fi
}

if [ "$UPLOAD" -eq 1 ]
then
    f5.file-transfer.upload "$PKCS12_FILE"
    PKCS12_FILE="/var/config/rest/downloads/$(basename "$PKCS12_FILE")"
fi

if ! JQ -n --arg f5_cert_name "$NAME" \
    --arg f5_file_path "$PKCS12_FILE" \
    --arg password "$PASSWORD" \
'{
    "command": "install",
    "name": $f5_cert_name,
    "from-local-file": $f5_file_path,
    "passphrase": $password
}' | POST "/mgmt/tm/sys/crypto/pkcs12"
then
    echo_err "PKCS12 installation failed."
    remove_upload_file
    exit 1
fi

echo "PKCS12 installation successful."
remove_upload_file
