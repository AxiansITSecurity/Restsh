# https://www.axians.de/security
# https://github.com/AxiansITSecurity/Restsh

# Shortdesc: Disables snmp v1 and v2c.
# Desc:
# Disables snmp v1 and v2c.

# Strict error handling
set -eEu -o pipefail

# Debug mode
[ -n "${RESTSH_DEBUG+x}" ] && set -x

if [ -z "${RESTSH_PATH+x}" ]
then
    echo "Script must be run in the restsh environment."
    exit 1
fi

# Get options
while getopts ':' OPTION
do
    case "$OPTION" in
        *) OPTION="invalid"; break ;;
    esac
done
shift "$((OPTIND -1))"

if [ "$OPTION" = "invalid" ]
then
    exec 1>&2
    _restsh.help.desc.get "$0"
    echo "Usage: $(basename "$0")"
    exit 2
fi

echo "Disabling snmpv1 and snmpv2c"
PATCH /mgmt/tm/sys/snmp <<< '{"snmpv1": "disable", "snmpv2c": "disable"}' > /dev/null

while read -r COMMUNITY
do
    echo "Deleting community $COMMUNITY"
    DELETE "/mgmt/tm/sys/snmp/communities/${COMMUNITY//\//\~}"
done < <(GET -r -f ".items[].fullPath" "/mgmt/tm/sys/snmp/communities")
