# https://github.com/AxiansITSecurity/Restsh

# Shortdesc: Lists all applications in an AS3 tenant.
# Desc:
# Lists all applications in an AS3 tenant.

# Strict error handling
set -eEu -o pipefail

# Debug mode
[ -n "${RESTSH_DEBUG+x}" ] && set -x

if [ -z "${RESTSH_PATH+x}" ]
then
    echo "Script must be run in the restsh environment."
    exit 1
fi

# Get options
RAW=0
while getopts ':r' OPTION
do
    case "$OPTION" in
        r) RAW=1 ;;
        *) OPTION="invalid"; break ;;
    esac
done
shift "$((OPTIND -1))"

if [ -z "${1+x}" ] || [ "$OPTION" == "invalid" ]
then
    exec 1>&2
    _restsh.help.desc.get "$0"
    echo "Usage: $(basename "$0") [options...] <tenant name>"
    echo "Options:"
    echo "    -r  Raw output."
    exit 2
fi
restsh.util.check.string "tenant name" "$1"; TENANT=$1

# Main
if RESULT=$(GET "/mgmt/shared/appsvcs/declare/${TENANT}/applications")
then
    if [ "$RAW" -eq 1 ]
    then
        JQ '.' <<< "$RESULT"
    else
        JQ -r 'keys[]' <<< "$RESULT" | grep -v schemaVersion
    fi
    exit 0
fi

exit 1
