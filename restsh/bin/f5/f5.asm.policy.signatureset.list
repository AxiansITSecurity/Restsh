#!/usr/bin/env bash

# Author: Juergen Mang <juergen.mang@axians.de>
# Date: 2025-03-04
# Shortdesc: Lists all attack signature sets attached to a WAF policy.
# Desc:
# Lists all attack signature sets attached to a WAF policy.

# Strict error handling
set -eEu -o pipefail

# Debug mode
[ -n "${RESTSH_DEBUG+x}" ] && set -x

if [ -z "${RESTSH_PATH+x}" ]
then
  echo "Script must be run in the restsh environment."
  exit 1
fi

# Get options
while getopts ':h' OPTION
do
    case "$OPTION" in
        *) OPTION="invalid"; break ;;
    esac
done
shift "$((OPTIND -1))"

if [ "$OPTION" = "invalid" ] || [ $# -ne 1 ]
then
    exec 1>&2
    _restsh.help.desc.get "$0"
    echo "Usage: $(basename "$0") <policy full path>"
    exit 2
fi
POLICY=$1

# Main
POLICY_HASH=$(f5.asm.policy.gethash "$POLICY")

GET "/mgmt/tm/asm/policies/$POLICY_HASH/signature-sets" \
    | JQ -r '.items[] | [.signatureSetReference.name,.id,.alarm,.block,.learn] | @tsv' \
    | COLUMN -o "|" -N "Name,Id,alarm,block,learn"
