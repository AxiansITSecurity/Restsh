#!/usr/bin/env bash

# Author: Juergen Mang <juergen.mang@axians.de>
# Date: 2024-07-08

# Shortdesc: Lists all instances.
# Desc:
# Lists all instances.

# Strict error handling
set -eEu -o pipefail

# Debug mode
[ -n "${RESTSH_DEBUG+x}" ] && set -x

if [ -z "${RESTSH_PATH+x}" ]
then
    echo "Script must be run in the restsh environment."
    exit 1
fi

RAW=0
while getopts ':d:krs:t' OPTION
do
    case "$OPTION" in
        r) RAW=1 ;;
        *) OPTION="invalid"; break ;;
    esac
done
shift "$((OPTIND -1))"

if [ "$OPTION" == "invalid" ]
then
    exec 1>&2
    _restsh.help.shortdesc.get "$0"
    echo "Usage: $(basename "$0") [-r]"
    echo -e "\t-r\tRaw output."
    exit 2
fi

# Check for a valid auth token
next.auth.check

if RESULT=$(GET "/api/v1/spaces/default/instances")
then
    if [ "$RAW" -eq 1 ]
    then
        JQ "." <<< "$RESULT"
    else
        JQ -r '._embedded.devices[] | [.hostname, .address, .mode, .version, .id] | @tsv' <<< "$RESULT" 2>/dev/null | \
            COLUMN -o "|" -N "Name,Address,Mode,Version,Id"
    fi
    exit 0
fi

exit 1
