#!/usr/bin/env bash

# Author: Juergen Mang <juergen.mang@axians.de>
# Date: 2024-06-21

# Shortdesc: Lists all WAF-Templates.
# Desc:
# Lists all WAF-Templates.

# Strict error handling
set -eEu -o pipefail

# Debug mode
[ -n "${RESTSH_DEBUG+x}" ] && set -x

if [ -z "${RESTSH_PATH+x}" ]
then
  echo "Script must be run in the restsh environment."
  exit 1
fi

# Get options
RAW=0
while getopts ':r' OPTION
do
    case "$OPTION" in
        r) RAW=1 ;;
        *) OPTION="invalid"; break ;;
    esac
done
shift "$((OPTIND -1))"

if [ "$OPTION" = "invalid" ]
then
    exec 1>&2
    _restsh.help.desc.get "$0"
    echo "Usage: $(basename "$0") [-r]"
    echo -e "\tUse -r for raw output."
    exit 2
fi

# Check for a valid auth token
next.auth.check

# Main
if RESULT=$(GET "${NEXT_API_PREFIX}/security/waf/policy-templates")
then
    if [ "$RAW" -eq 1 ]
    then
        echo "$RESULT"
    else
        $RESTSH_JQ -r '._embedded | .templates[] | [.name, .last_modified, .enforcement_mode, .id] | @tsv' <<< "$RESULT" | \
            COLUMN -o "|" -N "Name,Modified,Enforcement Mode,Id"
    fi
fi
