#!/usr/bin/env bash

# Author: Juergen Mang <juergen.mang@axians.de>
# Date: 2025-05-02

# Shortdesc: Lists all iRules.
# Desc:
# Lists all iRules.

# Strict error handling
set -eEu -o pipefail

# Debug mode
[ -n "${RESTSH_DEBUG+x}" ] && set -x

if [ -z "${RESTSH_PATH+x}" ]
then
  echo "Script must be run in the restsh environment."
  exit 1
fi

GET "/api/v1/spaces/default/irules?select=name" | JQ -r "._embedded.irules[].name"
exit 0
