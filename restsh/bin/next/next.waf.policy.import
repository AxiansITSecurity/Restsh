#!/usr/bin/env bash

# Author: Juergen Mang <juergen.mang@axians.de>
# Date: 2024-06-21

# Shortdesc: Imports a WAF Policy (Update or create).
# Desc:
# Imports a WAF Policy (Update or create).

# Strict error handling
set -eEu -o pipefail

# Debug mode
[ -n "${RESTSH_DEBUG+x}" ] && set -x

if [ -z "${RESTSH_PATH+x}" ]
then
    echo "Script must be run in the restsh environment."
    exit 1
fi

while getopts ':h' OPTION
do
    case "$OPTION" in
        *) OPTION="invalid"; break ;;
    esac
done
shift "$((OPTIND -1))"

if [ "$OPTION" = "invalid" ] || [ -z "${1+x}" ] || [ -z "${2+x}" ]
then
    exec 1>&2
    _restsh.help.shortdesc.get "$0"
    echo "Usage: $(basename "$0") <filename> <policy>"
    exit 2
fi
FILENAME=$1
POLICY=$2

# Check for a valid auth token
next.auth.check

if ! next.waf.policy.getid "$POLICY" > /dev/null 2>&1
then
    # Policy does not exist, create a new one
    next.waf.policy.create "$FILENAME"
else
    # Update existing policy
    next.waf.policy.update "$FILENAME" "$POLICY"
fi
