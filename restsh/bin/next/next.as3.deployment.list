#!/usr/bin/env bash

# Author: Juergen Mang <juergen.mang@axians.de>
# Date: 2024-07-04

# Shortdesc: Lists all deployments for specific document id.
# Desc:
# Request all the AS3 application services, their deployments details, and last deployment records.

# Strict error handling
set -eEu -o pipefail

# Debug mode
[ -n "${RESTSH_DEBUG+x}" ] && set -x

if [ -z "${RESTSH_PATH+x}" ]
then
    echo "Script must be run in the restsh environment."
    exit 1
fi

# Check for a valid auth token
next.auth.check

# Get options
RAW=0
while getopts ':r' OPTION
do
    case "$OPTION" in
        r) RAW=1 ;;
        *) OPTION="invalid"; break ;;
    esac
done
shift "$((OPTIND -1))"

if [ -z "${1+x}" ] || [ "$OPTION" == "invalid" ]
then
    exec 1>&2
    grep "^# Shortdesc" "$0" | sed 's/^# Shortdesc: //'
    echo "Usage: $(basename "$0") [-r] <document id>"
    echo -e "\t-r\tRaw output."
    exit 2
fi
DOCUMENT_ID=$1

# Main
if RESULT=$(GET -r "${NEXT_API_PREFIX}/spaces/default/appsvcs/documents/$DOCUMENT_ID")
then
    if [ "$RAW" -eq 0 ]
    then
        JQ -r '.deployments[] | [.target.instance_ip, .last_successful_deploy_time, .id, .last_record.status] | @tsv' <<< "$RESULT" | \
            COLUMN -o "|" -N "Instance,Deploy Time,Id,Status"
    else
        JQ '.deployments' <<< "$RESULT"
    fi
    exit 0
fi

echo "$RESULT"
exit 1
