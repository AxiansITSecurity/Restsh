#!/usr/bin/env bash

# Author: Juergen Mang <juergen.mang@axians.de>
# Date: 2024-03-21

# Shortdesc: Helper functions for private key files.
# Desc:
# Helper functions for private key files.

# Strict error handling
set -eEu -o pipefail

# Debug mode
[ -n "${RESTSH_DEBUG+x}" ] && set -x

if [ -z "${RESTSH_PATH+x}" ]
then
    echo "Script must be run in the restsh environment."
    exit 1
fi

if [ -n "${1+x}" ]
then
    ACTION=$1
else
    ACTION="invalid"
fi

if [ -n "${2+x}" ]
then
    case "$2" in
        rsa|ec) ALG=$2 ;;
        *)      ACTION="invalid" ;;
    esac
else
    ACTION="invalid"
fi

if [ -n "${3+x}" ]
then
    KEY_FILE=$3
else
    ACTION="invalid"
fi

# Prints help
usage() {
    echo "Usage:"
    echo -e "\tcert.key decrypt (rsa|ec) <key file>"
    echo -e "\tcert.key encrypt (rsa|ec) <key file>"
    echo -e "\tcert.key public (rsa|ec) <key file>"
    return 1
}

case "$ACTION" in
    "decrypt")
        openssl "$ALG" -in "$KEY_FILE"
        ;;
    "encrypt")
        openssl "$ALG" -in "$KEY_FILE" -aes256
        ;;
    "public")
        openssl "$ALG" -in "$KEY_FILE" -out "$KEY_FILE.pub"
        ;;
    *)
        usage
        ;;
esac

exit 0
