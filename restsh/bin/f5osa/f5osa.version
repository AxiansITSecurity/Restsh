#!/usr/bin/env bash

# Author: Juergen Mang <juergen.mang@axians.de>
# Date: 2025-09-09

# Shortdesc: Shows F5OS-A Version.
# Desc:
# Manages Shows F5OS-A Version.

# Strict error handling
set -eEu -o pipefail

# Debug mode
[ -n "${RESTSH_DEBUG+x}" ] && set -x

if [ -z "${RESTSH_PATH+x}" ]
then
    echo "Script must be run in the restsh environment."
    exit 1
fi

# Main
GET "$F5OSA_API_PREFIX/data/openconfig-system:system/f5-system-version:version"
