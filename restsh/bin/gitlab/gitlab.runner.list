#!/usr/bin/env bash

# Author: Juergen Mang <juergen.mang@axians.de>
# Date: 2024-12-13

# Shortdesc: Lists all runners.
# Desc:
# Lists all runners.

# Strict error handling
set -eEu -o pipefail

# Debug mode
[ -n "${RESTSH_DEBUG+x}" ] && set -x

if [ -z "${RESTSH_PATH+x}" ]
then
    echo "Script must be run in the restsh environment."
    exit 1
fi

# Get options
RAW=0
while getopts ':r' OPTION
do
    case "$OPTION" in
        r) RAW=1 ;;
        *) OPTION="invalid"; break ;;
    esac
done
shift "$((OPTIND -1))"

if [ "$OPTION" = "invalid" ]
then
    exec 1>&2
    _restsh.help.desc.get "$0"
    echo "Usage: $(basename "$0") [options...] [<page>]"
    echo "Options:"
    echo "    -r Raw output."
    exit 2
fi

PAGE=0
if [ -n "${1+x}" ]
then
    PAGE=$1
fi

if RESULT=$(GET "$GITLAB_API_PREFIX/runners/all?page=$PAGE&per_page=${GITLAB_PER_PAGE}")
then
    if [ "$RAW" -eq 1 ]
    then
        JQ "." <<< "$RESULT"
    else
        JQ -r '.[] | [.id, .description, .runner_type, .is_shared, .status] | @tsv' <<< "$RESULT" | \
            COLUMN -o "|" -N "id,description,type,shared,status"
    fi
    exit 0
fi

exit 1
