#!/usr/bin/env bash

# (c) Axians IT Security GmbH
# Jürgen Mang <juergen.mang@sec.axians.de>
# https://www.axians.de/security

# Shortdesc: Lists all group members.
# Desc:
# Lists all group members.

# Strict error handling
set -eEu -o pipefail

# Debug mode
[ -n "${RESTSH_DEBUG+x}" ] && set -x

if [ -z "${RESTSH_PATH+x}" ]
then
    echo "Script must be run in the restsh environment."
    exit 1
fi

# Get options
DIRECT="/all"
RAW=0
while getopts ':dr' OPTION
do
    case "$OPTION" in
        d) DIRECT="" ;;
        r) RAW=1 ;;
        *) OPTION="invalid"; break ;;
    esac
done
shift "$((OPTIND -1))"

if [ -z "${1+x}" ] || [ "$OPTION" = "invalid" ]
then
    exec 1>&2
    _restsh.help.desc.get "$0"
    echo "Usage: $(basename "$0") [options...] <group> [<page>]"
    echo "Options:"
    echo "    -r Raw output."
    exit 2
fi

restsh.util.check.string "group" "$1"; GROUP=$1
restsh.util.check.isnumber "$GROUP" || GROUP=$(restsh.util.urlencode "$GROUP")

PAGE=0
if [ -n "${2+x}" ]
then
    PAGE=$1
fi

if RESULT=$(GET "$GITLAB_API_PREFIX/groups/$GROUP/members${DIRECT}?page=$PAGE&per_page=${GITLAB_PER_PAGE}")
then
    if [ "$RAW" -eq 1 ]
    then
        JQ "." <<< "$RESULT"
    else
        JQ -r '.[] | [.id,.username, .access_level] | @tsv' <<< "$RESULT" | \
            COLUMN -o "|" -N "id,username,access_level"
    fi
else
    exit 1
fi

exit 0
