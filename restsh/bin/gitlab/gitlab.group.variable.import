#!/usr/bin/env bash

# (c) Axians IT Security GmbH
# Jürgen Mang <juergen.mang@sec.axians.de>
# https://www.axians.de/security

# Shortdesc: Imports CI/CD variables for a GitLab group.
# Desc:
# Imports CI/CD variables for a GitLab group.

# Strict error handling
set -eEu -o pipefail

# Debug mode
[ -n "${RESTSH_DEBUG+x}" ] && set -x

if [ -z "${RESTSH_PATH+x}" ]
then
    echo "Script must be run in the restsh environment."
    exit 1
fi

# Get options
while getopts ':' OPTION
do
    case "$OPTION" in
        *) OPTION="invalid"; break ;;
    esac
done
shift "$((OPTIND -1))"

if [ $# -ne 2 ] || [ "$OPTION" == "invalid" ]
then
    exec 1>&2
    _restsh.help.desc.get "$0"
    echo "Usage: $(basename "$0") <group> <filename>"
    exit 2
fi

GROUP=$1
FILENAME=$2
restsh.util.check.isnumber "$GROUP" || GROUP=$(restsh.util.urlencode "$GROUP")

while read -r LINE
do
    if ! RESULT=$(POST "$GITLAB_API_PREFIX/groups/$GROUP/variables" <<< "$LINE" 2>&1)
    then
        JQ -r '.error.output.message.key[0]' <<< "$RESULT"
    else
        echo -n "Imported variable "
        JQ -r '.key' <<< "$RESULT"
    fi
done < "$FILENAME"
