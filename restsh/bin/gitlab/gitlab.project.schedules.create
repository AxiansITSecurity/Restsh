#!/usr/bin/env bash

# Author: Juergen Mang <juergen.mang@axians.de>
# Date: 2025-04-04

# Shortdesc: Creates a schedule for a project pipeline.
# Desc:
# Creates a schedule for a project pipeline.

# Strict error handling
set -eEu -o pipefail

# Debug mode
[ -n "${RESTSH_DEBUG+x}" ] && set -x

if [ -z "${RESTSH_PATH+x}" ]
then
    echo "Script must be run in the restsh environment."
    exit 1
fi

# Get options
VARIABLES=()
TIMEZONE="Europe/Berlin"
while getopts ':s:' OPTION
do
    case "$OPTION" in
        s) VARIABLES+=("$OPTARG") ;;
        z) TIMEZONE=$OPTARG ;;
        *) OPTION="invalid"; break ;;
    esac
done
shift "$((OPTIND -1))"

if [ "$OPTION" = "invalid" ] || [ $# -ne 4 ]
then
    exec 1>&2
    _restsh.help.desc.get "$0"
    echo "Usage: $(basename "$0") [options...] <project> <branch> <cron> <description>"
    echo "Options:"
    echo "    -s <NAME>=<VALUE>  Set a variable"
    echo "    -z <timezone>      Set the timezone for cron, default: Europe/Berlin"
    exit 2
fi
PROJECT=$1
BRANCH=$2
CRON=$3
DESC=$4

restsh.util.check.isnumber "$PROJECT" || PROJECT=$(restsh.util.urlencode "$PROJECT")

if RESULT=$(JQ -n --arg ref "$BRANCH" --arg cron "$CRON" --arg desc "$DESC" --arg tz "$TIMEZONE"\
    '{
        ref: $ref,
        cron: $cron,
        description: $desc,
        cron_timezone: $tz
    }' | POST "$GITLAB_API_PREFIX/projects/$PROJECT/pipeline_schedules")
then
    ID=$(JQ '.id' <<< "$RESULT")
    for VAR in "${VARIABLES[@]}"
    do
        KEY=${VAR%%=*}
        VALUE=${VAR##*=}
        JQ -n --arg key "$KEY" --arg value "$VALUE" \
        '{
            key: $key,
            value: $value
        }' | POST "$GITLAB_API_PREFIX/projects/$PROJECT/pipeline_schedules/$ID/variables"
    done
    exit 0
fi
exit 1
