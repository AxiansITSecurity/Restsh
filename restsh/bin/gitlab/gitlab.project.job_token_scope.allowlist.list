#!/usr/bin/env bash

# (c) Axians IT Security GmbH
# Jürgen Mang <juergen.mang@sec.axians.de>
# https://www.axians.de/security

# Shortdesc: Lists all job token inbound allowlist items.
# Desc:
# Lists all job token inbound allowlist items.

# Strict error handling
set -eEu -o pipefail

# Debug mode
[ -n "${RESTSH_DEBUG+x}" ] && set -x

if [ -z "${RESTSH_PATH+x}" ]
then
    echo "Script must be run in the restsh environment."
    exit 1
fi

# Get options
RAW=0
while getopts ':r' OPTION
do
    case "$OPTION" in
        r) RAW=1 ;;
        *) OPTION="invalid"; break ;;
    esac
done
shift "$((OPTIND -1))"

if [ "$OPTION" = "invalid" ] || [ $# -lt 1 ]
then
    exec 1>&2
    _restsh.help.desc.get "$0"
    echo "Usage: $(basename "$0") [options...] <project> [<page>]"
    echo "Options:"
    echo "    -r Raw output."
    exit 2
fi

restsh.util.check.string "project" "$1"; PROJECT=$1
PAGE=0
if [ -n "${2+x}" ]
then
    restsh.util.check.uint "page" "$2"; PAGE=$2
fi

restsh.util.check.isnumber "$PROJECT" || PROJECT=$(gitlab.project.id "$PROJECT")

TARGET_GROUPS=$(GET -r "$GITLAB_API_PREFIX/projects/$PROJECT/job_token_scope/groups_allowlist?page=$PAGE&per_page=${GITLAB_PER_PAGE}")
TARGET_PROJECTS=$(GET -r "$GITLAB_API_PREFIX/projects/$PROJECT/job_token_scope/allowlist?page=$PAGE&per_page=${GITLAB_PER_PAGE}")

if [ "$RAW" -eq 1 ]
then
    JQ "." <<< "$TARGET_GROUPS"
    JQ "." <<< "$TARGET_PROJECTS"
else
    JQ -r '.[] | [.id, .web_url] | @tsv' <<< "$TARGET_GROUPS" \
        | sed -E -e 's/https:\/\/[^\/]+\/groups\///' \
        | COLUMN -o "|" -N "id,group"
    echo ""
    JQ -r '.[] | [.id, .path_with_namespace] | @tsv' <<< "$TARGET_PROJECTS" \
        | COLUMN -o "|" -N "id,project"
fi
