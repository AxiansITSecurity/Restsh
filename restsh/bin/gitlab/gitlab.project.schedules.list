#!/usr/bin/env bash

# Author: Juergen Mang <juergen.mang@axians.de>
# Date: 2025-04-04

# Shortdesc: Lists all pipeline schedules from a project.
# Desc:
# Lists all pipeline schedules from a project.

# Strict error handling
set -eEu -o pipefail

# Debug mode
[ -n "${RESTSH_DEBUG+x}" ] && set -x

if [ -z "${RESTSH_PATH+x}" ]
then
    echo "Script must be run in the restsh environment."
    exit 1
fi

# Get options
RAW=0
while getopts ':r' OPTION
do
    case "$OPTION" in
        r) RAW=1 ;;
        *) OPTION="invalid"; break ;;
    esac
done
shift "$((OPTIND -1))"

if [ "$OPTION" = "invalid" ] || [ $# -ne 1 ]
then
    exec 1>&2
    _restsh.help.desc.get "$0"
    echo "Usage: $(basename "$0") [-r] <project>"
    echo -e "\tUse -r for raw output."
    exit 2
fi
PROJECT=$1
restsh.util.check.isnumber "$PROJECT" || PROJECT=$(restsh.util.urlencode "$PROJECT")

if RESULT=$(GET "$GITLAB_API_PREFIX/projects/$PROJECT/pipeline_schedules")
then
    if [ "$RAW" -eq 1 ]
    then
        echo "$RESULT"
    else
        JQ -r '.[] | [.id,.active,.description,.cron] | @tsv' <<< "$RESULT" | \
            COLUMN -o "|" -N "ID,Active,Description,Cron"
    fi
    exit 0
fi

exit 1
