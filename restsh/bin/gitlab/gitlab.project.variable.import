# Shortdesc: Imports CI/CD variables for a GitLab project.
# Desc:
# Imports CI/CD variables for a GitLab project.

# Strict error handling
set -eEu -o pipefail

# Debug mode
[ -n "${RESTSH_DEBUG+x}" ] && set -x

if [ -z "${RESTSH_PATH+x}" ]
then
    echo "Script must be run in the restsh environment."
    exit 1
fi

# Get options
while getopts ':' OPTION
do
    case "$OPTION" in
        *) OPTION="invalid"; break ;;
    esac
done
shift "$((OPTIND -1))"

if [ $# -ne 2 ] || [ "$OPTION" == "invalid" ]
then
    exec 1>&2
    _restsh.help.desc.get "$0"
    echo "Usage: $(basename "$0") <project> <filename>"
    exit 2
fi

restsh.util.check.string "project" "$1"; PROJECT=$1
restsh.util.check.string "filename" "$1"; FILENAME=$2

restsh.util.check.isnumber "$PROJECT" || PROJECT=$(restsh.util.urlencode "$PROJECT")

while read -r LINE
do
    if ! RESULT=$(POST "$GITLAB_API_PREFIX/projects/$PROJECT/variables" <<< "$LINE" 2>&1)
    then
        JQ -r '.error.output.message.key[0]' <<< "$RESULT"
    else
        echo -n "Imported variable "
        JQ -r '.key' <<< "$RESULT"
    fi
done < "$FILENAME"
