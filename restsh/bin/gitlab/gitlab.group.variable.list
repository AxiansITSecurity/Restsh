#!/usr/bin/env bash

# Author: Juergen Mang <juergen.mang@axians.de>
# Date: 2024-05-08

# Shortdesc: Lists all group variables.
# Desc:
# Lists all group variables.

# Strict error handling
set -eEu -o pipefail

# Debug mode
[ -n "${RESTSH_DEBUG+x}" ] && set -x

if [ -z "${RESTSH_PATH+x}" ]
then
    echo "Script must be run in the restsh environment."
    exit 1
fi

# Get options
RAW=0
while getopts ':r' OPTION
do
    case "$OPTION" in
        r) RAW=1 ;;
        *) OPTION="invalid"; break ;;
    esac
done
shift "$((OPTIND -1))"

if [ $# -ne 1 ] ||[ "$OPTION" == "invalid" ]
then
    exec 1>&2
    restsh.help.shortdesc.get "$0"
    echo "Usage: $(basename "$0") [-r] <group id>"
    echo -e "\tUse -r for raw output."
    exit 1
fi

GROUP=$1

if RESULT=$(GET "$GITLAB_API_PREFIX/groups/$GROUP/variables")
then
    if [ "$RAW" -eq 1 ]
    then
        echo "$RESULT"
    else
        JQ -r '.[] | [.key, .value, .masked, .raw] | @tsv' <<< "$RESULT" | \
            COLUMN -ts $'\t' -o " | " -N "key,value,masked,raw"
    fi
else
    exit 1
fi

exit 0
