#!/usr/bin/env bash

# Author: Juergen Mang <juergen.mang@axians.de>
# Date: 2025-02-19

# Shortdesc: Lists all merge requests for a project.
# Desc:
# Lists all merge requests for a project.

# Strict error handling
set -eEu -o pipefail

# Debug mode
[ -n "${RESTSH_DEBUG+x}" ] && set -x

if [ -z "${RESTSH_PATH+x}" ]
then
    echo "Script must be run in the restsh environment."
    exit 1
fi

# Get options
RAW=0
while getopts ':r' OPTION
do
    case "$OPTION" in
        r) RAW=1 ;;
        *) OPTION="invalid"; break ;;
    esac
done
shift "$((OPTIND -1))"

if [ "$#" -lt 1 ] || [ "$OPTION" = "invalid" ]
then
    exec 1>&2
    _restsh.help.desc.get "$0"
    echo "Usage: $(basename "$0") [options...] <project> [<page>]"
    echo "Options:"
    echo "    -r Raw output."
    exit 2
fi

PROJECT=$1
restsh.util.check.isnumber "$PROJECT" || PROJECT=$(restsh.util.urlencode "$PROJECT")

PAGE=0
if [ -n "${2+x}" ]
then
    PAGE=$2
fi

if RESULT=$(GET "$GITLAB_API_PREFIX/projects/$PROJECT/merge_requests?state=opened&page=$PAGE&per_page=${GITLAB_PER_PAGE}")
then
    if [ "$RAW" -eq 1 ]
    then
        JQ "." <<< "$RESULT"
    else
        JQ -r '.[] | [.iid, .merge_status, .source_branch, .target_branch, .author.name] | @tsv' <<< "$RESULT" | \
            COLUMN -o "|" -N "id,merge status,source,target,author"
    fi
    exit 0
fi

exit 1
