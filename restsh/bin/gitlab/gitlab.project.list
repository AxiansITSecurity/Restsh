#!/usr/bin/env bash

# Author: Juergen Mang <juergen.mang@axians.de>
# Date: 2024-05-13

# Shortdesc: Lists all projects.
# Desc:
# Lists all projects.

# Strict error handling
set -eEu -o pipefail

# Debug mode
[ -n "${RESTSH_DEBUG+x}" ] && set -x

if [ -z "${RESTSH_PATH+x}" ]
then
    echo "Script must be run in the restsh environment."
    exit 1
fi

# Get options
RAW=0
while getopts ':r' OPTION
do
    case "$OPTION" in
        r) RAW=1 ;;
        *) OPTION="invalid"; break ;;
    esac
done
shift "$((OPTIND -1))"

if [ "$OPTION" = "invalid" ]
then
    exec 1>&2
    _restsh.help.desc.get "$0"
    echo "Usage: $(basename "$0") [-r] [<page>]"
    echo -e "\tUse -r for raw output."
    exit 2
fi

PAGE=0
if [ -n "${1+x}" ]
then
    PAGE=$1
fi

if RESULT=$(GET "$GITLAB_API_PREFIX/projects?page=$PAGE&per_page=${GITLAB_PER_PAGE}")
then
    if [ "$RAW" -eq 1 ]
    then
        echo "$RESULT"
    else
        JQ -r '.[] | [.id, .path_with_namespace, .owner.username] | @tsv' <<< "$RESULT" | \
            COLUMN -o "|" -N "id,path_with_namespace,owner"
    fi
    exit 0
fi

exit 1
