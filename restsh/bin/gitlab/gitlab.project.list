# https://github.com/AxiansITSecurity/Restsh

# Shortdesc: Lists all projects.
# Desc:
# Lists all projects.

# Strict error handling
set -eEu -o pipefail

# Debug mode
[ -n "${RESTSH_DEBUG+x}" ] && set -x

if [ -z "${RESTSH_PATH+x}" ]
then
    echo "Script must be run in the restsh environment."
    exit 1
fi

# Get options
RAW=0
ALL=0
while getopts ':ar' OPTION
do
    case "$OPTION" in
        a) ALL=1 ;;
        r) RAW=1 ;;
        *) OPTION="invalid"; break ;;
    esac
done
shift "$((OPTIND -1))"

if [ "$OPTION" = "invalid" ]
then
    exec 1>&2
    _restsh.help.desc.get "$0"
    echo "Usage: $(basename "$0") [options...] [<page>]"
    echo "Options:"
    echo "    -a Show all projects"
    echo "    -r Raw output."
    exit 2
fi

PAGE=0
if [ -n "${1+x}" ]
then
    restsh.util.check.uint "page" "$1"; PAGE=$1
fi

if RESULT=$(GET "$GITLAB_API_PREFIX/projects?page=$PAGE&per_page=${GITLAB_PER_PAGE}")
then
    if [ "$RAW" -eq 1 ]
    then
        if [ "$ALL" -eq 1 ]
        then
            JQ "." <<< "$RESULT"
        else
            JQ '.[] | [select(.archived == false)]' <<< "$RESULT"
        fi
    else
        if [ "$ALL" -eq 1 ]
        then
            JQ -r '.[] | [.id, .path_with_namespace, .archived] | @tsv' <<< "$RESULT" | \
                COLUMN -o "|" -N "id,path_with_namespace,archived"
        else
            JQ -r '.[] | select(.archived == false) | [.id, .path_with_namespace] | @tsv' <<< "$RESULT" | \
                COLUMN -o "|" -N "id,path_with_namespace"
        fi
    fi
    exit 0
fi

exit 1
