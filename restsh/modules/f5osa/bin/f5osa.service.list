# https://github.com/AxiansITSecurity/Restsh

# Shortdesc: Lists all dockerized F5OS-A services
# Desc:
# Lists all dockerized F5OS-A services
# Reference: https://clouddocs.f5.com/api/rseries-api/F5OS-A-1.8.4-api.html?section=f5-system-diagnostics-docker#tag/get

# Strict error handling
set -eEu -o pipefail

# Debug mode
[ -n "${RESTSH_DEBUG+x}" ] && set -x

if [ -z "${RESTSH_PATH+x}" ]
then
    echo "Script must be run in the restsh environment."
    exit 1
fi

# Get options
RAW=0
while getopts ':r' OPTION
do
    case "$OPTION" in
        r) RAW=1 ;;
        *) OPTION="invalid"; break ;;
    esac
done
shift "$((OPTIND -1))"

if [ "$OPTION" == "invalid" ]
then
    exec 1>&2
    _restsh.help.desc.get "$0"
    echo "Usage: $(basename "$0") <service>"
    exit 2
fi

# Main
if [ "$RAW" -eq 1 ]
then
    GET "${F5OSA_API_PREFIX}/data/openconfig-system:system/f5-system-diagnostics-qkview:diagnostics/f5-system-diagnostics-docker:os-utils"
else
    GET "${F5OSA_API_PREFIX}/data/openconfig-system:system/f5-system-diagnostics-qkview:diagnostics/f5-system-diagnostics-docker:os-utils" \
        | JQ -r '."f5-system-diagnostics-docker:os-utils".docker.nodes.node[].services.service[] | [.name,.state.status] | @tsv' \
        | COLUMN -o "|" -N "Service,State"
fi
