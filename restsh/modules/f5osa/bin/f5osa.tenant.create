#!/usr/bin/env bash

# SPDX-License-Identifier: GPL-3.0-or-later
# (c) Axians IT Security GmbH
# Jürgen Mang <juergen.mang@sec.axians.de>
# https://www.axians.de/security
# https://github.com/AxiansITSecurity/Restsh

# Shortdesc: Creates a tenant.
# Desc:
# Reference: https://clouddocs.f5.com/training/community/rseries-training/html/rseries_deploying_a_tenant.html#creating-a-tenant-via-api
# Example tenant template: restsh/modules/f5osa/templates/tenant.json

# Strict error handling
set -eEu -o pipefail

# Debug mode
[ -n "${RESTSH_DEBUG+x}" ] && set -x

if [ -z "${RESTSH_PATH+x}" ]
then
    echo "Script must be run in the restsh environment."
    exit 1
fi

# Get options
IS_TEMPLATE=0
KEEP_TMP=0
DEFAULTS=""
while getopts ':d:kts:' OPTION
do
    case "$OPTION" in
        d) restsh.util.check.string "defaults file" "$OPTARG"; DEFAULTS=$OPTARG ;;
        e) PRINT_EXAMPLE=1 ;;
        k) KEEP_TMP=1 ;;
        t) IS_TEMPLATE=1 ;;
        s) restsh.util.declare.var "$OPTARG" ;;
        *) OPTION="invalid"; break ;;
    esac
done
shift "$((OPTIND -1))"

if [ "$OPTION" == "invalid" ] || [ "$#" -ne 1 ]
then
    exec 1>&2
    _restsh.help.shortdesc.get "$0"
    echo "Usage: $(basename "$0") [options...] <declaration file>"
    echo "Options:"
    echo "    -d <variables file>  Define a custom variable file."
    echo "    -e                   Print example template and exit."
    echo "    -k                   Keeps the temporary files."
    echo "    -sVAR=VALUE          Define a custom variable."
    echo "    -t                   Process the declaration file with mustache."
    echo ""
    _restsh.help.desc.get "$0"
    echo_ok "Example template file:"
    cat "$RESTSH_PATH/modules/f5osa/templates/tenant.json"
    echo ""
    echo_ok "Example variable file:"
    cat "$RESTSH_PATH/modules/f5osa/templates/tenant.var"
    exit 2
fi

restsh.util.check.filename "Declaration file" "$1"; DECLARATION_FILE=$1
DECLARATION_FILE_PARSED="$RESTSH_TMP/$(basename "$DECLARATION_FILE")"

# Cleanup tmp files
[ "$KEEP_TMP" -eq 1 ] || trap 'rm -f -- "$DECLARATION_FILE_PARSED"' EXIT

# Main

# Run mustache
if [ "$IS_TEMPLATE" -eq 1 ]
then
    # Include mustache
    . "${RESTSH_PATH}/dist/mo/mo"
    . "${RESTSH_PATH}/lib/mo/mo.functions"

    # Load variables file
    MO_OPTIONS=()
    if [ -n "$DEFAULTS" ]
    then
        if [ ! -s "$DEFAULTS" ]
        then
            echo_err "Variables file not found."
            exit 1
        fi
        MO_OPTIONS+=("-s=""$DEFAULTS")
    fi

    # Process template
    if ! $RESTSH_MO "${MO_OPTIONS[@]}" -- "$DECLARATION_FILE" > "$DECLARATION_FILE_PARSED"
    then
        echo_err "Processing the template failed."
        exit 1
    fi
else
    cp "$DECLARATION_FILE" "$DECLARATION_FILE_PARSED"
fi

# Post the declaration
POST "$F5OSA_API_PREFIX/data/f5-tenants:tenants" < "$DECLARATION_FILE_PARSED"
