# Shortdesc: Downloads an external system datagroup.
# Desc:
# Downloads an external system datagroup.

# Strict error handling
set -eEu -o pipefail

# Debug mode
[ -n "${RESTSH_DEBUG+x}" ] && set -x

if [ -z "${RESTSH_PATH+x}" ]
then
  echo "Script must be run in the restsh environment."
  exit 1
fi

while getopts ':h' OPTION
do
    case "$OPTION" in
        *) OPTION="invalid"; break ;;
    esac
done
shift "$((OPTIND -1))"

if [ "$OPTION" = "invalid" ] || [ $# -ne 2 ]
then
  exec 1>&2
  _restsh.help.desc.get "$0"
  echo "Usage: $(basename "$0") <full path> <filename>"
  exit 2
fi

restsh.util.check.string "full path" "$1"; FULLPATH=${1//\//\~}
restsh.util.check.string "filename" "$2"; FILENAME=$2

FILE=$(GET -rf ".cachePath" "/mgmt/tm/sys/file/data-group/${FULLPATH}?options=-hidden")
f5.run "base64" "$FILE" | base64 -d > "$FILENAME"
