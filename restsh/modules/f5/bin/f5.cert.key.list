# https://github.com/AxiansITSecurity/Restsh

# Shortdesc: Lists traffic management certificate keys on the F5.
# Desc:
# Lists traffic management certificate keys on the F5.

# Strict error handling
set -eEu -o pipefail

# Debug mode
[ -n "${RESTSH_DEBUG+x}" ] && set -x

if [ -z "${RESTSH_PATH+x}" ]
then
    echo "Script must be run in the restsh environment."
    exit 1
fi

# Get options
RAW=0
while getopts ':r' OPTION
do
    case "$OPTION" in
        r) RAW=1 ;;
        *) OPTION="invalid"; break ;;
    esac
done
shift "$((OPTIND -1))"

if [ "$OPTION" = "invalid" ]
then
    exec 1>&2
    _restsh.help.desc.get "$0"
    echo "Usage: $(basename "$0") [options...]"
    echo "Options:"
    echo  "    -r Raw output."
    exit 2
fi

if RESULT=$(GET "/mgmt/tm/sys/file/ssl-key?options=-hidden")
then
    if [ "$RAW" -eq 1 ]
    then
        JQ "." <<< "$RESULT"
    else
        $RESTSH_JQ -r '.items[] | [.fullPath, .keyType, .keySize] | @tsv' <<< "$RESULT" | \
            COLUMN -o " | " -N "fullPath,keyType,keySize"
    fi
    exit 0
fi

exit 1
