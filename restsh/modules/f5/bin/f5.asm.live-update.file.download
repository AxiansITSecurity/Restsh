# Shortdesc: Downloads a live-update file.
# Desc:
# Downloads a live-update file.
# Reference: https://my.f5.com/manage/s/article/K000150184

# Strict error handling
set -eEu -o pipefail

# Debug mode
[ -n "${RESTSH_DEBUG+x}" ] && set -x

if [ -z "${RESTSH_PATH+x}" ]
then
    echo "Script must be run in the restsh environment."
    exit 1
fi

# Get options
while getopts ':' OPTION
do
    case "$OPTION" in
        *) OPTION="invalid"; break ;;
    esac
done
shift "$((OPTIND -1))"

if [ "$OPTION" == "invalid" ] || [ $# -ne 1 ]
then
    exec 1>&2
    _restsh.help.desc.get "$0"
    echo "Usage: $(basename "$0") <file>"
    exit 2
fi
restsh.util.check.string "file" "$1"; FILE=$1
FILENAME=$(basename "$FILE")


f5.run "cp" "-v" "/var/lib/hsqldb/live-update/update-files/$FILENAME" "/shared/images/$FILENAME"
if f5.file.download "/mgmt/cm/autodeploy/software-image-downloads" "$FILENAME" 0 "$FILENAME"
then
    f5.run "rm" "-f" "/shared/images/$FILENAME"
else
    f5.run "rm" "-f" "/shared/images/$FILENAME"
fi
