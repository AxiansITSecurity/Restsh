# https://github.com/AxiansITSecurity/Restsh

# Shortdesc: Lists EPSEC Packages.
# Desc:
# Lists EPSEC Packages.

# Strict error handling
set -eEu -o pipefail

# Debug mode
[ -n "${RESTSH_DEBUG+x}" ] && set -x

if [ -z "${RESTSH_PATH+x}" ]
then
  echo "Script must be run in the restsh environment."
  exit 1
fi

# Get options
RAW=0
while getopts ':r' OPTION
do
    case "$OPTION" in
        r) RAW=1 ;;
        *) OPTION="invalid"; break ;;
    esac
done
shift "$((OPTIND -1))"

if [ "$OPTION" = "invalid" ]
then
    exec 1>&2
    _restsh.help.desc.get "$0"
    echo "Usage: $(basename "$0") [options...]"
    echo "Options:"
    echo "    -r Raw output."
    exit 2
fi

if [ "$RAW" -eq 1 ]
then
    GET "/mgmt/tm/apm/epsec/epsec-package"
else
    INSTALLED_VERSION=$(GET -r /mgmt/tm/apm/epsec/software-status/ \
    | JQ -r '.. | objects | with_entries(select(.key | contains("version"))) | select(. != {}) | .version.description')
    echo "Installed version: $INSTALLED_VERSION"
    GET "/mgmt/tm/apm/epsec/epsec-package" \
        | JQ -r '.items[] | [.fullPath,.systemPackage,.version] | @tsv' \
        | COLUMN -o "|" -N "fullPath,SystemPackage,Version"
fi
