# https://github.com/AxiansITSecurity/Restsh

# Shortdesc: Lists all custom signature sets.
# Desc:
# Lists all custom signature sets.

# Strict error handling
set -eEu -o pipefail

# Debug mode
[ -n "${RESTSH_DEBUG+x}" ] && set -x

if [ -z "${RESTSH_PATH+x}" ]
then
    echo "Script must be run in the restsh environment."
    exit 1
fi

# Get options
RAW=0
FILTER=""
while getopts ':ru' OPTION
do
    case "$OPTION" in
        r) RAW=1 ;;
        u) FILTER="&\$filter=isUserDefined%20eq%20true" ;;
        *) OPTION="invalid"; break ;;
    esac
done
shift "$((OPTIND -1))"

if [ "$OPTION" == "invalid" ]
then
    exec 1>&2
    _restsh.help.desc.get "$0"
    echo "Usage: $(basename "$0") [options...]"
    echo "Options:"
    echo "    -r Raw output."
    echo "    -u Show only user defined signature sets"
    exit 2
fi

# Main
if RESULT=$(GET "/mgmt/tm/asm/signature-sets?\$select=name,id,signatureCount,isUserDefined${FILTER}")
then
    if [ "$RAW" -eq 1 ]
    then
        echo "$RESULT"
    else
        JQ -r '.items[] | [.name,.id,.signatureCount] | @tsv' <<< "$RESULT" | \
            COLUMN -o "|" -N "Name,Id,Count"
    fi
    exit 0
fi

exit 1
