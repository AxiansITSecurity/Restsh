# Shortdesc: Downloads a System iFile.
# Desc:
# Downloads a System iFile.

# Strict error handling
set -eEu -o pipefail

# Debug mode
[ -n "${RESTSH_DEBUG+x}" ] && set -x

if [ -z "${RESTSH_PATH+x}" ]
then
    echo "Script must be run in the restsh environment."
    exit 1
fi

while getopts ':h' OPTION
do
    case "$OPTION" in
        *) OPTION="invalid"; break ;;
    esac
done
shift "$((OPTIND -1))"

if [ "$OPTION" = "invalid" ] || [ $# -ne 2 ]
then
    exec 1>&2
    _restsh.help.desc.get "$0"
    echo "Usage: $(basename "$0") <fullPath> <filename>"
    exit 2
fi

restsh.util.check.string "fullPath" "$1"; FULLPATH=${1//\//\~}
restsh.util.check.string "filename" "$1"; FILENAME=$2

FILE=$(GET -rf ".cachePath" "/mgmt/tm/sys/file/ifile/${FULLPATH}?options=-hidden")
f5.run "base64" "$FILE" | base64 -d > "$FILENAME"
