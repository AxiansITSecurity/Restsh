# https://github.com/AxiansITSecurity/Restsh

# Shortdesc: Lists all attack signature in a policy.
# Desc:
# Lists all attack signature in a policy.

# Strict error handling
set -eEu -o pipefail

# Debug mode
[ -n "${RESTSH_DEBUG+x}" ] && set -x

if [ -z "${RESTSH_PATH+x}" ]
then
  echo "Script must be run in the restsh environment."
  exit 1
fi

RAW=0
while getopts ':hr' OPTION
do
    case "$OPTION" in
        r) RAW=1 ;;
        *) OPTION="invalid"; break ;;
    esac
done
shift "$((OPTIND -1))"

if [ "$OPTION" = "invalid" ] || [ $# -ne 1 ]
then
    exec 1>&2
    _restsh.help.desc.get "$0"
    echo "Usage: $(basename "$0") <policy fullPath>"
    exit 2
fi

restsh.util.check.string "policy fullPath" "$1"; POLICY=$1
POLICY_HASH=$(f5.asm.policy.gethash "$POLICY")

if [ "$RAW" -eq 1 ]
then
    GET "/mgmt/tm/asm/policies/$POLICY_HASH/signatures/"
else
    GET -rf '.items[] | [.id,.signatureReference.signatureId,.enabled,.alarm,.block,.learn,.performStaging,.signatureReference.name] | @tsv' \
        "/mgmt/tm/asm/policies/$POLICY_HASH/signatures/" \
        | COLUMN -o "|" -N "Id,signatureId,Enabled,Alarm,Block,Learn,Staging,Name"
fi
