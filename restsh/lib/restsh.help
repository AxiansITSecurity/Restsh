#!/usr/bin/env bash

# Author: Juergen Mang <juergen.mang@axians.de>
# Date: 2024-07-24

# Shortdesc: Displays this help.
# Desc:
# Displays all commands and the short description.

# Strict error handling
set -uo pipefail

# Debug mode
[ -n "${RESTSH_DEBUG+x}" ] && set -x

# Indents the lines by one tab
_indent() {
    while read -r LINE
    do
        echo -e "\t$LINE"
    done
}

# Parses the file for functions and its descriptions.
# The description must be directly above the function definition.
_restsh.help.parse.lib() {
    local LAST_LINES=()
    while read -r LINE
    do
        if [ "${LINE:0:1}" = "#" ]
        then
            LAST_LINES+=("${LINE:2}")
        elif [[ "$LINE" == *"() {" ]]
        then
            LINE="${LINE%%\(*}"
            CMDS["$LINE"]=$(printf "%s\n" "${LAST_LINES[@]}")
            LAST_LINES=()
        else
            LAST_LINES=()
        fi
    done < "$1"
}

# Prints the CMDS array with full description.
_restsh.help.print.multiline() {
    local K
    for K in "${!CMDS[@]}"
    do
        echo -e "$K\n${CMDS["$K"]}"
        echo ""
    done
    unset CMDS
}

# Prints the CMDS array and the first line of the description.
# Output is formated in columns.
_restsh.help.print() {
    local K
    for K in "${!CMDS[@]}"
    do
        local DESC=${CMDS["$K"]}
        DESC="${DESC%%$'\n'*}"
        echo -e "$K\t$DESC"
    done | sort | COLUMN | _indent
    unset CMDS
}

# Show version info
restsh.help.version() {
    cat << EOL

restsh $RESTSH_VERSION
(c) Axians IT-Security GmbH
Juergen Mang <juergen.mang@axians.de>
EOL
}

# Show environment
restsh.help.showenv() {
    echo "Environment variables:"
    local LINE
    while read -r LINE
    do
        echo -e "\t$LINE"
    done < <(export | grep "declare -x RESTSH" | \
        sed -E -e 's/declare -x //' -e "s/(RESTSH_PASS=).*/\1\"***\"/" \
            -e "s/(RESTSH_TOKEN_VALUE=).*/\1\"***\"/" \
            -e "s/(RESTSH_REFRESH_TOKEN=).*/\1\"***\"/" \
            -e "s/(RESTSH_SECRET=).*/\1\"***\"/"| \
        sort | sed -e 's/=/\t/' | COLUMN)
}

# Prints additional modules
restsh.help.modules() {
    # Print all custom modules
    echo "Enabled modules:"
    local MODULE
    {
        for MODULE in "${RESTSH_MODULES[@]}"
        do
            local DESC=""
            [ -f "$RESTSH_PATH/bin/$MODULE/.shortdesc" ] && DESC=$(<"$RESTSH_PATH/bin/$MODULE/.shortdesc")
            [ -f "$RESTSH_PATH/lib/$MODULE/.shortdesc" ] && DESC=$(<"$RESTSH_PATH/lib/$MODULE/.shortdesc")
            echo -e "$MODULE\t$DESC"
        done
    } | COLUMN | _indent
}

# Prints all commands from a module
_restsh.help.modules.cmds() {
    local MODULE=$1
    echo ""
    echo "$MODULE commands:"
    declare -A CMDS
    if [ -d "$RESTSH_PATH/lib/$MODULE" ]
    then
        while read -r FILE
        do
            _restsh.help.parse.lib "$FILE"
        done < <(find "$RESTSH_PATH/lib/$MODULE" -type f)
    fi
    if [ -d "$RESTSH_PATH/bin/$MODULE" ]
    then
        while read -r FILE
        do
            DESC=$(_restsh.help.shortdesc.get "$FILE")
            FILE="${FILE##*/}"
            [ "$FILE" == ".shortdesc" ] && continue
            CMDS[$FILE]=$DESC
        done < <(find "$RESTSH_PATH/bin/$MODULE" -type f ! -name .\*)
    fi
    _restsh.help.print
}

# Displays this help.
restsh.help() {
    if [ -z "${1+x}" ]
    then
        MODULES="none"
    else
        MODULES=$1
    fi

    restsh.help.version
    echo ""
    restsh.help.showenv
    echo ""
    # First print restsh internal commands
    echo "HTTP commands:"
    declare -A CMDS
    _restsh.help.parse.lib "$RESTSH_PATH/lib/restsh.http"
    _restsh.help.print
    echo ""
    echo "Vault commands:"
    declare -A CMDS
    _restsh.help.parse.lib "$RESTSH_PATH/lib/restsh.vault"
    _restsh.help.print
    echo ""
    echo "Utility commands:"
    declare -A CMDS
    _restsh.help.parse.lib "$RESTSH_PATH/lib/restsh.util"
    _restsh.help.print
    _restsh.help.modules.cmds "restsh"

    if [ "$MODULES" == "none" ]
    then
        # Print additional modules
        echo ""
        restsh.help.modules
    elif [ "$MODULES" == "all" ]
    then
        # Print all module commands
        local MODULE
        for MODULE in "${RESTSH_MODULES[@]}"
        do
            _restsh.help.modules.cmds "$MODULE"
        done
    else
        # Print commands from one module
        _restsh.help.modules.cmds "$MODULES"
    fi
}

# Prints the short description
_restsh.help.shortdesc.get() {
    while read -r LINE
    do
        if [ "${LINE:0:12}" = "# Shortdesc:" ]
        then
            echo "${LINE:13}"
            break
        fi
    done < "$1"
}

# Prints the full description
_restsh.help.desc.get() {
    local LINE
    local P=0
    while read -r LINE
    do
        if [ "$LINE" = "# Desc:" ]
        then
            P=1
        elif [ "$P" -eq 1 ]
        then
            [ "${LINE:0:1}" != "#" ] && break
            echo "${LINE:2}"
        fi
    done < "$1"
    echo ""
}

# Prints the reference description
_restsh.help.reference.get() {
    while read -r LINE
    do
        if [ "${LINE:0:12}" = "# Reference:" ]
        then
            echo "${LINE:13}"
            break
        fi
    done < "$1"
}

export -f restsh.help
export -f restsh.help.modules
export -f _restsh.help.shortdesc.get
export -f _restsh.help.desc.get
export -f _restsh.help.reference.get
export -f restsh.help.showenv
export -f restsh.help.version
