# Desc:
# Common functions and definitions for the F5 Next module.

# Strict error handling
set -uo pipefail

# Debug mode
[ -n "${RESTSH_DEBUG+x}" ] && set -x

# Prefix for the F5 Next REST API
export NEXT_API_PREFIX="/api/v1"
