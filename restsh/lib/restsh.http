        echo -e "\tPipe the payload in the command."
        echo -e "\tUse -r for raw output."
        return 1
    fi
    restsh.http "${ARGS[@]}" PUT "$1"
}

export -f restsh.http
export -f DELETE
export -f GET
export -f PATCH
export -f POST
export -f PUT
