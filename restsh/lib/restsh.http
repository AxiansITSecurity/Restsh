# Issues a PUT request
PUT() {
    local ARGS=("-b")
    local OPTION OPTIND
    while getopts ':r' OPTION
    do
        case "$OPTION" in
            r) ARGS+=("-r") ;;
            *) OPTION="invalid"; break ;;
        esac
    done
    shift "$((OPTIND -1))"
    if [ -z "${1+x}" ] || [ "$OPTION" == "invalid" ]
    then
        echo "Usage: PUT [-r] <uri>"
        echo -e "\tPipe the payload in the command."
        echo -e "\tUse -r for raw output."
        return 1
    fi
    ARGS+=("PUT" "$1")
    restsh.http "${ARGS[@]}"
}

export -f restsh.http
export -f restsh.download
export -f restsh.upload
export -f DELETE
export -f GET
export -f PATCH
export -f POST
export -f PUT
