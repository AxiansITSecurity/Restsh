# Issues a PUT request
PUT() {
    local ARGS=("-b")
    local OPTION OPTIND
    while getopts ':r' OPTION
    do
        case "$OPTION" in
            r) ARGS+=("-r") ;;
            *) OPTION="invalid" ;;
