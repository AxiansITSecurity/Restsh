    local ARGS=("-b")
    local OPTION OPTIND
    while getopts ':rc:' OPTION
    do
        case "$OPTION" in
            r) ARGS+=("-r") ;;
            c) ARGS+=("-c" "$OPTARG") ;;
            *) OPTION="invalid"; break ;;
        esac
    done
    shift "$((OPTIND -1))"
    if [ -z "${1+x}" ] || [ "$OPTION" == "invalid" ]
    then
        echo "Usage: POST [-r] [-c] <uri>" 1>&2
        echo -e "\tPipe the payload in the command." 1>&2
        echo -e "\tUse -r for raw output." 1>&2
        echo -e "\tUse -c to define retries." 1>&2
        return 1
    fi
    ARGS+=("POST" "$1")
    restsh.http "${ARGS[@]}"
}

# Issues a PUT request
PUT() {
    local ARGS=("-b")
    local OPTION OPTIND
    while getopts ':rc:' OPTION
    do
        case "$OPTION" in
            r) ARGS+=("-r") ;;
            c) ARGS+=("-c" "$OPTARG") ;;
            *) OPTION="invalid"; break ;;
        esac
    done
    shift "$((OPTIND -1))"
    if [ -z "${1+x}" ] || [ "$OPTION" == "invalid" ]
    then
        echo "Usage: PUT [-r] [-c] <uri>" 1>&2
        echo -e "\tPipe the payload in the command." 1>&2
        echo -e "\tUse -r for raw output." 1>&2
        echo -e "\tUse -c to define retries." 1>&2
        return 1
    fi
    ARGS+=("PUT" "$1")
    restsh.http "${ARGS[@]}"
}

export -f restsh.http
export -f restsh.download
export -f restsh.upload
export -f DELETE
export -f DOWNLOAD
export -f GET
export -f OPTIONS
export -f PATCH
export -f POST
export -f PUT
