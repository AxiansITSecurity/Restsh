#!/usr/bin/env bash

# Author: Juergen Mang <juergen.mang@axians.de>
# Date: 2023-08-02

# Shortdesc: Central http functions for all common REST methods.
# Desc:
# Central http functions for all common REST methods.

# Strict error handling
set -uo pipefail

# Debug mode
[ -n "${RESTSH_DEBUG+x}" ] && set -x

# Generic http request function
restsh.http() {
    local BODY=0
    local RAW=0
    local OPTION OPTIND
    while getopts ':br' OPTION
    do
        case "$OPTION" in
            b) BODY=1 ;;
            r) RAW=1 ;;
            *) OPTION="invalid"; break ;;
        esac
    done
    shift "$((OPTIND -1))"
    if [ -z "${1+x}" ] || [ -z "${2+x}" ] || [ "$OPTION" == "invalid" ]
    then
        echo "Usage: restsh.http [-b] [-r] <method> <uri>"
        echo -e "\tUse -b for a body and pipe the payload in the command."
        echo -e "\tUse -r for raw output."
        return 1
    fi
    local METHOD=$1
    local URI=$2

    # We must set the curl options first
    restsh.util.setcurloptions

    if [ "$BODY" -eq 1 ]
    then
        # Read body from STDIN
        RESTSH_CURL_OPTS+=("-d" "@-")
        # Add header
        RESTSH_CURL_OPTS+=("-H" "Content-Type: $RESTSH_CONTENT")
    fi

    if ! OUTPUT=$($RESTSH_CURL_BIN "${RESTSH_CURL_OPTS[@]}" -X "$METHOD" "${RESTSH_URL}${URI}")
    then
        echo_err "$METHOD ${RESTSH_URL}${URI} failed"
        echo_err "$OUTPUT"
        unset RESTSH_CURL_OPTS
        return 1
    fi
    unset RESTSH_CURL_OPTS
    if [ "$RAW" -eq 1 ]
    then
        echo "$OUTPUT"
    else
        restsh.util.parseoutput "$OUTPUT"
    fi
    return 0
}

# Download a file in chunks (default 512kB).
restsh.download() {
    if [ -z "${1+x}" ] || [ -z "${2+x}" ] || [ -z "${3+x}" ]
    then
        echo "Download a file in chunks of 512kB."
        echo "Usage: restsh.download <uri> <size> <filename>"
        return 1
    fi
    local URI=$1
    local TOTAL_SIZE=$2
    local FILENAME=$3

    # We must set the curl options first
    restsh.util.setcurloptions

    # Remove local file
    rm -f "${FILENAME}"

    # Download file in chunks, range header is zero-indexed
    # and includes range start and end.
    TOTAL_SIZE=$((TOTAL_SIZE-1))
    local START=0
    local END=0
    local CHUNK_SIZE=$RESTSH_CHUNK_SIZE
    [ "$TOTAL_SIZE" -lt "$CHUNK_SIZE" ] && CHUNK_SIZE=$TOTAL_SIZE

    # Initialize Connection type at Keep-Alive
	local CONNECTION="Keep-Alive"

    while [ "$END" -lt "$TOTAL_SIZE" ]
    do
        END=$((START+CHUNK_SIZE-1))
        if [ "$END" -gt "$TOTAL_SIZE" ]
        then
            END=$TOTAL_SIZE
            CONNECTION="Close"
        fi
        echo "${START}-${END}/${TOTAL_SIZE}"
        if ! $RESTSH_CURL_BIN \
            -H "Content-Range: ${START}-${END}/${TOTAL_SIZE}" \
            -H "Connection: $CONNECTION" \
            "${RESTSH_CURL_OPTS[@]}" "${RESTSH_URL}${URI}" \
            >> "${FILENAME}"
        then
            echo_err "Download failed"
            unset RESTSH_CURL_OPTS
            return 1
        fi
        START=$((END+1))
    done
    unset RESTSH_CURL_OPTS
    return 0
}

# Uploads a file in chunks (default 512kB).
restsh.upload() {
    if [ -z "${1+x}" ] || [ -z "${2+x}" ]
    then
        echo "Upload a file in chunks of 512kB."
        echo "Usage: restsh.upload <uri> <filename>"
        return 1
    fi
    local URI=$1
    local FILENAME=$2
    local TOTAL_SIZE
    if ! TOTAL_SIZE=$(stat -c%s "$FILENAME")
    then
        echo "File \"$FILENAME\" not found."
        return 1
    fi

    # We must set the curl options first
    restsh.util.setcurloptions

    # Upload file in chunks, range header is zero-indexed
    # and includes range start and end.
    TOTAL_SIZE=$((TOTAL_SIZE-1))
    local START=0
    local END=0
    local CHUNK_SIZE=$RESTSH_CHUNK_SIZE
    [ "$TOTAL_SIZE" -lt "$CHUNK_SIZE" ] && CHUNK_SIZE=$TOTAL_SIZE

    # Initialize Connection type at Keep-Alive
	local CONNECTION="Keep-Alive"

    TMPFILE=$(mktemp)
    SKIP=0
    while [ "$END" -lt "$TOTAL_SIZE" ]
    do
        END=$((START+CHUNK_SIZE-1))
        if [ "$END" -gt "$TOTAL_SIZE" ]
        then
            END=$TOTAL_SIZE
            CONNECTION="Close"
        fi
        echo "${START}-${END}/${TOTAL_SIZE}"
        dd status=none if="$FILENAME" of="$TMPFILE" count=1 skip="$SKIP" bs="$CHUNK_SIZE"
        if ! OUTPUT=$($RESTSH_CURL_BIN \
            -H "Content-Range: ${START}-${END}/${TOTAL_SIZE}" \
            -H "Content-Type: application/octet-stream" \
            -H "Connection: $CONNECTION" \
            "${RESTSH_CURL_OPTS[@]}" "${RESTSH_URL}${URI}" \
            --data-binary @"$TMPFILE")
        then
            echo_err "Upload failed"
            echo_err "$OUTPUT"
            unset RESTSH_CURL_OPTS
            return 1
        fi
        START=$((END+1))
        SKIP=$((SKIP+1))
    done
    unset RESTSH_CURL_OPTS
    rm -f "$TMPFILE"
    return 0
}

# Issues a DELETE request
DELETE() {
    local ARGS=()
    local OPTION OPTIND
    while getopts ':r' OPTION
    do
        case "$OPTION" in
            r) ARGS+=("-r") ;;
            *) OPTION="invalid"; break ;;
        esac
    done
    shift "$((OPTIND -1))"
    if [ -z "${1+x}" ] || [ "$OPTION" == "invalid" ]
    then
        echo "Usage: DELETE [-r] <uri>"
        echo -e "\tUse -r for raw output."
        return 1
    fi
    ARGS+=("DELETE" "$1")
    restsh.http "${ARGS[@]}"
}

