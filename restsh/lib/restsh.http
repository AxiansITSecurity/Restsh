        echo -e "\tUse -r for raw output."
        echo -e "\tUse -c to define retries."
        return 1
    fi
    ARGS+=("GET" "$1")
    restsh.http "${ARGS[@]}"
}

# Issues a PATCH request
PATCH() {
    local ARGS=("-b")
    local OPTION OPTIND
    while getopts ':rc:' OPTION
    do
        case "$OPTION" in
            r) ARGS+=("-r") ;;
            c) ARGS+=("-c" "$OPTARG") ;;
            *) OPTION="invalid"; break ;;
        esac
    done
    shift "$((OPTIND -1))"
    if [ -z "${1+x}" ] || [ "$OPTION" == "invalid" ]
    then
        echo "Usage: PATCH [-r] <uri>"
        echo -e "\tPipe the payload in the command."
        echo -e "\tUse -r for raw output."
        echo -e "\tUse -c to define retries."
        return 1
    fi
    ARGS+=("PATCH" "$1")
    restsh.http "${ARGS[@]}"
}

