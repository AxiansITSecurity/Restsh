    local ARGS=()
    local OPTION OPTIND
    while getopts ':rc:' OPTION
    do
        case "$OPTION" in
            r) ARGS+=("-r") ;;
            c) ARGS+=("-c" "$OPTARG") ;;
            *) OPTION="invalid"; break ;;
