# Issues a PUT request
PUT() {
    local ARGS=("-b")
    local OPTION OPTIND
    while getopts ':rc:' OPTION
    do
        case "$OPTION" in
            r) ARGS+=("-r") ;;
            c) ARGS+=("-c" "$OPTARG") ;;
            *) OPTION="invalid"; break ;;
